        },
        {
          "command": "lumina.footer.showAskHeapStack",
          "when": "true"
        },
        {
          "command": "lumina.footer.showNotifications",
          "when": "true"
        },
        {
          "command": "lumina.fileCleanupStack.addCurrent",
          "when": "true"
        },
        {
          "command": "lumina.fileCleanupStack.refresh",
          "when": "true"
