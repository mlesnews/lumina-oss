        {
          "command": "lumina.fileCleanupStack.addFilesWithDiagnostics",
          "when": "true"
        }
      ],
      "editor/context": [
        {
          "command": "lumina.copyAgentRequestIdUrl",
          "when": "editorTextFocus",
          "group": "navigation"
        },
        {
          "command": "lumina.fileAutoClose.pinFile",
          "when": "editorTextFocus",
          "group": "lumina@1"
        },
        {
          "command": "lumina.fileAutoClose.unpinFile",
          "when": "editorTextFocus",
          "group": "lumina@1"
        },
        {
          "command": "lumina.fileAutoClose.closeFile",
          "when": "editorTextFocus",
          "group": "lumina@1"
        },
        {
          "command": "lumina.fileAutoClose.evaluateFile",
          "when": "editorTextFocus",
          "group": "lumina@1"
        }
      ],
      "explorer/context": [
        {
          "command": "lumina.copyAgentRequestIdUrl",
          "when": "explorerResourceIsFile",
          "group": "navigation"
        },
        {
          "command": "lumina.fileAutoClose.pinFile",
          "when": "resourceExtname != ''",
          "group": "lumina@1"
        },
        {
          "command": "lumina.fileAutoClose.unpinFile",
          "when": "resourceExtname != ''",
          "group": "lumina@1"
        },
        {
          "command": "lumina.fileAutoClose.evaluateFile",
          "when": "resourceExtname != ''",
          "group": "lumina@1"
        }
      ],
      "view/item/context": [
        {
          "command": "lumina.fileCleanupStack.remove",
          "when": "view == lumina.fileCleanupStack",
          "group": "inline"
        },
        {
          "command": "lumina.fileCleanupStack.open",
          "when": "view == lumina.fileCleanupStack",
          "group": "inline"
        }
      ]
    },
    "statusBar": {
      "alignment": "right",
      "priority": 100
    },
    "statusBarItems": [
      {
        "id": "lumina.progress",
        "name": "LUMINA Progress",
        "alignment": "left",
        "priority": 100
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package",
    "publish": "echo FORBIDDEN: Do not publish Lumina extensions. VSIX only. See docs/system/LUMINA_EXTENSION_VSIX_ONLY.md && exit 1"
  },
  "dependencies": {
    "axios": "^1.7.9"
