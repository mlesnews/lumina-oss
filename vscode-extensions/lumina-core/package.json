{
  "name": "lumina-core",
  "displayName": "Lumina Core - Open Source Lumina Ecosystem",
  "description": "Lumina Core - Open source Lumina ecosystem with Lumina AI Chat (Cursor Chat + voice, status, queue), GitHub/GitLens, local enterprise Git, NAS cloud services, storage provider configurations, real-time todo status tracking with @PEAK quantification, unified queue, footer ticker, file auto-close, and agent request ID sharing",
  "version": "2.1.1",
  "publisher": "lumina",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Git",
    "Cloud"
  ],
  "keywords": [
    "lumina",
    "lumina ai chat",
    "jarvis",
    "git",
    "github",
    "gitlens",
    "nas",
    "cloud",
    "storage",
    "enterprise"
  ],
  "activationEvents": [
    "*",
    "onStartupFinished",
    "onView:lumina.fileCleanupStack",
    "onCommand:lumina.resetProgressDisplay",
    "onCommand:lumina.showProgress",
    "onCommand:lumina.showOutput"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lumina.openLuminaAIChat",
        "title": "Open Lumina AI Chat",
        "category": "Lumina"
      },
      {
        "command": "lumina.openJarvisChat",
        "title": "Open JARVIS Chat",
        "category": "Lumina"
      },
      {
        "command": "lumina.acceptAllChanges",
        "title": "Accept All Changes (Chat / Composer)",
        "category": "Lumina"
      },
      {
        "command": "lumina.showStatus",
        "title": "Show Lumina Status"
      },
      {
        "command": "lumina.showOutput",
        "title": "Show Lumina Core Output",
        "category": "Lumina"
      },
      {
        "command": "lumina.showActiveModels",
        "title": "Show Active AI Models"
      },
      {
        "command": "lumina.showGitStatus",
        "title": "Show Git/GitLens Status"
      },
      {
        "command": "lumina.showNASStatus",
        "title": "Show NAS Cloud Services Status"
      },
      {
        "command": "lumina.showStorageProviders",
        "title": "Show Storage Providers"
      },
      {
        "command": "lumina.syncToNAS",
        "title": "Sync to NAS"
      },
      {
        "command": "lumina.autoStartLocalAI",
        "title": "Auto-Start Local AI Services"
      },
      {
        "command": "lumina.showTodoStatus",
        "title": "Show Todo Status (@MASTER/@PADAWAN)"
      },
      {
        "command": "lumina.refreshTodoStatus",
        "title": "Refresh Todo Status"
      },
      {
        "command": "lumina.showTPSReport",
        "title": "Show TPS Report (Daily Morning Briefing)"
      },
      {
        "command": "lumina.generateTPSReport",
        "title": "Generate TPS Report"
      },
      {
        "command": "lumina.showLiveAIModelStatus",
        "title": "Show LIVE AI Model Status (Forensic Audit)"
      },
      {
        "command": "lumina.monitorLiveAIModel",
        "title": "Monitor LIVE AI Model"
      },
      {
        "command": "lumina.copyAgentRequestIdUrl",
        "title": "Copy Request ID Internal URL"
      },
      {
        "command": "lumina.applyKiloCodeSetup",
        "title": "Apply Kilo Code Setup",
        "category": "Lumina"
      },
      {
        "command": "lumina.showProgress",
        "title": "Show LUMINA Progress"
      },
      {
        "command": "lumina.resetProgressDisplay",
        "title": "Reset LUMINA Progress Display (unstall green bar)"
      },
      {
        "command": "lumina.footer.showAskHeapStack",
        "title": "Show Ask Heap Stack"
      },
      {
        "command": "lumina.footer.showNotifications",
        "title": "Show Notifications [IDE-QUEUE]"
      },
      {
        "command": "lumina.fileAutoClose.closeFile",
        "title": "Lumina: Close File (Auto-Close System)",
        "category": "Lumina"
      },
      {
        "command": "lumina.fileAutoClose.pinFile",
        "title": "Lumina: Pin File (Prevent Auto-Close)",
        "category": "Lumina"
      },
      {
        "command": "lumina.fileAutoClose.unpinFile",
        "title": "Lumina: Unpin File (Allow Auto-Close)",
        "category": "Lumina"
      },
      {
        "command": "lumina.fileAutoClose.showStatus",
        "title": "Lumina: Show Auto-Close Status",
        "category": "Lumina"
      },
      {
        "command": "lumina.fileAutoClose.evaluateFile",
        "title": "Lumina: Evaluate File for Closing (@V3 + @JARVIS)",
        "category": "Lumina"
      },
      {
        "command": "lumina.unifiedQueue.showDetails",
        "title": "Show Queue Details",
        "category": "LUMINA"
      },
      {
        "command": "lumina.unifiedQueue.openViewer",
        "title": "Open Queue Viewer",
        "category": "LUMINA"
      },
      {
        "command": "lumina.unifiedQueue.refresh",
        "title": "Refresh Queue Status",
        "category": "LUMINA"
      },
      {
        "command": "lumina.footerTicker.toggle",
        "title": "Toggle Footer Ticker",
        "category": "LUMINA"
      },
      {
        "command": "lumina.voiceControls.play",
        "title": "Lumina: Voice Controls - Play",
        "category": "Lumina"
      },
      {
        "command": "lumina.voiceControls.pause",
        "title": "Lumina: Voice Controls - Pause",
        "category": "Lumina"
      },
      {
        "command": "lumina.voiceControls.stop",
        "title": "Lumina: Voice Controls - Stop",
        "category": "Lumina"
      },
      {
        "command": "lumina.voiceControls.toggle",
        "title": "Lumina: Voice Controls - Toggle",
        "category": "Lumina"
      },
      {
        "command": "lumina.voiceRequestQueue.open",
        "title": "Open Voice Request Queue",
        "category": "Lumina"
      },
      {
        "command": "lumina.voiceRequestQueue.addCurrent",
        "title": "Add Current to Voice Queue",
        "category": "Lumina"
      },
      {
        "command": "lumina.voiceRequestQueue.setListeningModeActive",
        "title": "Set Listening Mode - Active",
        "category": "Lumina"
      },
      {
        "command": "lumina.voiceRequestQueue.setListeningModePassive",
        "title": "Set Listening Mode - Passive",
        "category": "Lumina"
      },
      {
        "command": "lumina.activeModelStatus.showDetails",
        "title": "Lumina: Show Active Model Details",
        "category": "Lumina"
      },
      {
        "command": "lumina.activeModelStatus.refresh",
        "title": "Lumina: Refresh Active Model Status",
        "category": "Lumina"
      },
      {
        "command": "lumina.fileCleanupStack.addCurrent",
        "title": "Add Current File to Cleanup Stack",
        "category": "Lumina"
      },
      {
        "command": "lumina.fileCleanupStack.remove",
        "title": "Remove from Cleanup Stack",
        "category": "Lumina"
      },
      {
        "command": "lumina.fileCleanupStack.refresh",
        "title": "Refresh Cleanup Stack",
        "category": "Lumina"
      },
      {
        "command": "lumina.fileCleanupStack.open",
        "title": "Open File",
        "category": "Lumina"
      },
      {
        "command": "lumina.fileCleanupStack.addFilesWithDiagnostics",
        "title": "Add All Files With Problems to Stack",
        "category": "Lumina"
      },
      {
        "command": "lumina.fileCleanupStack.focus",
        "title": "Focus File Cleanup Stack",
        "category": "Lumina"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lumina",
          "title": "Lumina",
          "icon": "$(sparkle)"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "lumina.fileCleanupStack",
          "name": "File Cleanup Stack"
        }
      ]
    },
    "configuration": {
      "title": "Lumina Core",
      "properties": {
        "lumina.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Lumina ecosystem integration"
        },
        "lumina.git.github": {
          "type": "object",
          "default": {
            "enabled": true,
            "public": true,
            "private": true
          },
          "description": "GitHub integration settings (public and private repositories)"
        },
        "lumina.git.gitlens": {
          "type": "object",
          "default": {
            "enabled": true,
            "automaticFollowup": true,
            "prIntegration": true
          },
          "description": "GitLens integration settings"
        },
        "lumina.git.localEnterprise": {
          "type": "object",
          "default": {
            "enabled": true,
            "nasPath": "G:\\git\\repositories",
            "autoSync": true
          },
          "description": "Local enterprise Git configuration"
        },
        "lumina.nas.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable NAS cloud services"
        },
        "lumina.nas.ip": {
          "type": "string",
          "default": "<NAS_PRIMARY_IP>",
          "description": "NAS IP address"
        },
        "lumina.nas.path": {
          "type": "string",
          "default": "N:\\",
          "description": "NAS network drive path"
        },
        "lumina.storage.providers": {
          "type": "array",
          "default": [
            "dropbox",
            "onedrive",
            "protondrive",
            "nas"
          ],
          "description": "Enabled storage providers"
        },
        "lumina.storage.aggregatedPath": {
          "type": "string",
          "default": "N:\\cloud_storage_aggregated",
          "description": "Aggregated cloud storage path"
        },
        "lumina.ai.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Auto-start local AI services (ULTRON/KAIJU)"
        },
        "lumina.ai.resourceAwareness": {
          "type": "boolean",
          "default": true,
          "description": "Enable resource-aware scaling"
        },
        "lumina.ai.cpuThreshold": {
          "type": "number",
          "default": 70,
          "description": "CPU threshold for scaling (percentage)"
        },
        "lumina.todo.statusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show todo status in status bar"
        },
        "lumina.todo.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Auto-refresh todo status on file changes"
        },
        "lumina.todo.refreshInterval": {
          "type": "number",
          "default": 30000,
          "description": "Todo status refresh interval in milliseconds (default: 30 seconds)"
        },
        "lumina.fileAutoClose.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic file closing"
        },
        "lumina.fileAutoClose.autoCloseMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 480,
          "description": "Minutes after which to auto-close files"
        },
        "lumina.fileAutoClose.checkIntervalSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "maximum": 300,
          "description": "How often to check for files to close (seconds)"
        },
        "lumina.fileAutoClose.jarvisOverrideEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable JARVIS override decisioning"
        },
        "lumina.fileAutoClose.v3ConfidenceThreshold": {
          "type": "number",
          "default": 0.7,
          "minimum": 0.1,
          "maximum": 1,
          "description": "V3 decision confidence threshold"
        },
        "lumina.fileAutoClose.showNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications when closing files"
        },
        "lumina.editorValidation.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Run Ruff + Mypy validation when focus leaves editor (after buffer)"
        },
        "lumina.editorValidation.bufferMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 120,
          "description": "Minutes after last file save before first run (don't run while editing)"
        },
        "lumina.editorValidation.intervalMinutes": {
          "type": "number",
          "default": 10,
          "minimum": 5,
          "maximum": 60,
          "description": "Minutes between runs when focus is off editor"
        },
        "lumina.editorValidation.checkIntervalSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 30,
          "maximum": 300,
          "description": "How often to check focus/buffer (seconds)"
        },
        "lumina.unifiedQueue.showInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show unified queue status in status bar"
        },
        "lumina.unifiedQueue.updateInterval": {
          "type": "number",
          "default": 2000,
          "description": "Update interval in milliseconds"
        },
        "lumina.unifiedQueue.showDetails": {
          "type": "boolean",
          "default": true,
          "description": "Show details on click"
        },
        "lumina.footerTicker.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable footer ticker banner"
        },
        "lumina.footerTicker.scrollSpeed": {
          "type": "number",
          "default": 30,
          "description": "Scroll speed in pixels per second"
        },
        "lumina.footerTicker.itemSpacing": {
          "type": "number",
          "default": 50,
          "description": "Spacing between items in pixels"
        },
        "lumina.footerTicker.pauseOnHover": {
          "type": "boolean",
          "default": true,
          "description": "Pause scrolling when hovering over ticker"
        },
        "lumina.voiceControls.autoHide": {
          "type": "boolean",
          "default": true,
          "description": "Auto-hide voice controls status bar when not in use"
        },
        "lumina.voiceControls.autoHideDelay": {
          "type": "number",
          "default": 2000,
          "description": "Delay in milliseconds before auto-hiding voice controls"
        },
        "lumina.voiceControls.autoSend": {
          "type": "boolean",
          "default": true,
          "description": "Enable hands-free auto-send after pause"
        },
        "lumina.voiceControls.pauseDuration": {
          "type": "number",
          "default": 4000,
          "minimum": 3000,
          "maximum": 5000,
          "description": "Pause duration in milliseconds before auto-sending (3-5 seconds)"
        },
        "lumina.voiceRequestQueue.listeningMode": {
          "type": "string",
          "enum": [
            "active",
            "passive"
          ],
          "default": "active",
          "description": "Listening mode: active = auto-send or add to queue; passive = voice segments go to Voice Request Queue only (no auto-send)"
        },
        "lumina.activeModelStatus.showInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show active model status in status bar"
        },
        "lumina.activeModelStatus.updateInterval": {
          "type": "number",
          "default": 1000,
          "description": "Update interval in milliseconds"
        },
        "lumina.progress.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable airport signboard style progress indicator for JARVIS/AI/Agents"
        },
        "lumina.progress.updateInterval": {
          "type": "number",
          "default": 2000,
          "description": "Progress status update interval in milliseconds"
        },
        "lumina.footer.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable LUMINA footer customization"
        },
        "lumina.footer.showAskHeapStack": {
          "type": "boolean",
          "default": true,
          "description": "Show (#/#) #ask-heap-stack prefix"
        },
        "lumina.footer.showNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show (N) #notifications [IDE-QUEUE] suffix"
        }
      }
    },
    "menus": {
      "commandPalette": [
