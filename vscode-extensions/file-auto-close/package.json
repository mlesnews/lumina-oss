{
  "name": "lumina-file-auto-close",
  "displayName": "Lumina File Auto-Close",
  "description": "Automatically closes files after 30 minutes unless pinned, with JARVIS decisioning",
  "version": "1.0.0",
  "publisher": "lumina",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "luminaFileAutoClose.closeFile",
        "title": "Lumina: Close File (Auto-Close System)",
        "category": "Lumina"
      },
      {
        "command": "luminaFileAutoClose.pinFile",
        "title": "Lumina: Pin File (Prevent Auto-Close)",
        "category": "Lumina"
      },
      {
        "command": "luminaFileAutoClose.unpinFile",
        "title": "Lumina: Unpin File (Allow Auto-Close)",
        "category": "Lumina"
      },
      {
        "command": "luminaFileAutoClose.showStatus",
        "title": "Lumina: Show Auto-Close Status",
        "category": "Lumina"
      },
      {
        "command": "luminaFileAutoClose.evaluateFile",
        "title": "Lumina: Evaluate File for Closing (@V3 + @JARVIS)",
        "category": "Lumina"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "luminaFileAutoClose.pinFile",
          "when": "resourceExtname != ''",
          "group": "lumina@1"
        },
        {
          "command": "luminaFileAutoClose.unpinFile",
          "when": "resourceExtname != ''",
          "group": "lumina@1"
        },
        {
          "command": "luminaFileAutoClose.evaluateFile",
          "when": "resourceExtname != ''",
          "group": "lumina@1"
        }
      ],
      "editor/title/context": [
        {
          "command": "luminaFileAutoClose.pinFile",
          "group": "lumina@1"
        },
        {
          "command": "luminaFileAutoClose.unpinFile",
          "group": "lumina@1"
        },
        {
          "command": "luminaFileAutoClose.closeFile",
          "group": "lumina@1"
        },
        {
          "command": "luminaFileAutoClose.evaluateFile",
          "group": "lumina@1"
        }
      ]
    },
    "configuration": {
      "title": "Lumina File Auto-Close",
      "properties": {
        "luminaFileAutoClose.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic file closing"
        },
        "luminaFileAutoClose.autoCloseMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 480,
          "description": "Minutes after which to auto-close files"
        },
        "luminaFileAutoClose.checkIntervalSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "maximum": 300,
          "description": "How often to check for files to close (seconds)"
        },
        "luminaFileAutoClose.jarvisOverrideEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable JARVIS override decisioning"
        },
        "luminaFileAutoClose.v3ConfidenceThreshold": {
          "type": "number",
          "default": 0.7,
          "minimum": 0.1,
          "maximum": 1.0,
          "description": "V3 decision confidence threshold"
        },
        "luminaFileAutoClose.showNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications when closing files"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "eslint": "^8.34.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^4.9.5",
    "@vscode/test-electron": "^2.3.0"
  }
}



