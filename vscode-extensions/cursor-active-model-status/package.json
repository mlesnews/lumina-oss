{
  "name": "cursor-active-model-status",
  "displayName": "Cursor Active Model Status",
  "description": "Displays the currently active model in Cursor IDE",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorActiveModelStatus.refresh",
        "title": "Refresh Active Model Status"
      },
      {
        "command": "cursorActiveModelStatus.showDetails",
        "title": "Show Active Model Details"
      }
    ],
    "configuration": {
      "title": "Cursor Active Model Status",
      "properties": {
        "cursorActiveModelStatus.updateInterval": {
          "type": "number",
          "default": 1000,
          "description": "Update interval in milliseconds",
          "minimum": 500
        },
        "cursorActiveModelStatus.showInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show active model in status bar"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
