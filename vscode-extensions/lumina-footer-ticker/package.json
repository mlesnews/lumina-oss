{
  "name": "lumina-footer-ticker",
  "displayName": "LUMINA Footer Ticker Banner",
  "description": "Real operational data in Cursor footer - AI model, GPU, TODOs, tickets, git status",
  "version": "1.1.0",
  "publisher": "lumina",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lumina.footerTicker.toggle",
        "title": "LUMINA: Toggle Footer Ticker"
      },
      {
        "command": "lumina.footerTicker.refresh",
        "title": "LUMINA: Refresh Footer Data"
      }
    ],
    "configuration": {
      "title": "LUMINA Footer Ticker",
      "properties": {
        "lumina.footerTicker.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable footer ticker banner"
        },
        "lumina.footerTicker.scrollSpeed": {
          "type": "number",
          "default": 30,
          "description": "Scroll speed in pixels per second"
        },
        "lumina.footerTicker.itemSpacing": {
          "type": "number",
          "default": 50,
          "description": "Spacing between items in pixels"
        },
        "lumina.footerTicker.pauseOnHover": {
          "type": "boolean",
          "default": true,
          "description": "Pause scrolling when hovering over ticker"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "tags": [
    "lumina",
    "footer",
    "ticker",
    "banner",
    "status-bar",
    "operational-data"
  ]
}
