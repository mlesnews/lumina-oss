{
  "name": "cursor-voice-controls",
  "displayName": "Cursor Voice Controls",
  "description": "Full VCR controls (Play, Pause, Stop) for Cursor voice transcription",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorVoiceControls.play",
        "title": "▶ Play Voice Transcription"
      },
      {
        "command": "cursorVoiceControls.pause",
        "title": "⏸ Pause Voice Transcription"
      },
      {
        "command": "cursorVoiceControls.stop",
        "title": "⏹ Stop Voice Transcription"
      },
      {
        "command": "cursorVoiceControls.toggle",
        "title": "Toggle Voice Transcription"
      },
      {
        "command": "cursorVoiceControls.skipForward",
        "title": "⏩ Skip Forward (Next Segment)"
      },
      {
        "command": "cursorVoiceControls.skipBack",
        "title": "⏪ Skip Back (Previous Segment)"
      },
      {
        "command": "cursorVoiceControls.fastForward",
        "title": "⏩⏩ Fast Forward (Skip Ahead)"
      },
      {
        "command": "cursorVoiceControls.fastRewind",
        "title": "⏪⏪ Fast Rewind (Skip Back)"
      },
      {
        "command": "cursorVoiceControls.toggleAutoHide",
        "title": "Toggle Auto-Hide"
      },
      {
        "command": "cursorVoiceControls.toggleAutoSend",
        "title": "Toggle Auto-Send (Hands-Free)"
      },
      {
        "command": "cursorVoiceControls.cancelAutoSend",
        "title": "Cancel Auto-Send"
      }
    ],
    "keybindings": [
      {
        "command": "cursorVoiceControls.play",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v"
      },
      {
        "command": "cursorVoiceControls.pause",
        "key": "ctrl+shift+p",
        "mac": "cmd+shift+p"
      },
      {
        "command": "cursorVoiceControls.stop",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s"
      },
      {
        "command": "cursorVoiceControls.skipForward",
        "key": "ctrl+shift+right",
        "mac": "cmd+shift+right"
      },
      {
        "command": "cursorVoiceControls.skipBack",
        "key": "ctrl+shift+left",
        "mac": "cmd+shift+left"
      },
      {
        "command": "cursorVoiceControls.fastForward",
        "key": "ctrl+shift+up",
        "mac": "cmd+shift+up"
      },
      {
        "command": "cursorVoiceControls.fastRewind",
        "key": "ctrl+shift+down",
        "mac": "cmd+shift+down"
      },
      {
        "command": "cursorVoiceControls.cancelAutoSend",
        "key": "ctrl+shift+escape",
        "mac": "cmd+shift+escape"
      }
    ],
    "configuration": {
      "title": "Cursor Voice Controls",
      "properties": {
        "cursorVoiceControls.autoHide": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable auto-hide for the voice control status bar item."
        },
        "cursorVoiceControls.autoHideDelay": {
          "type": "number",
          "default": 2000,
          "description": "Delay in milliseconds before the status bar item auto-hides when voice is stopped and not hovered (min 500, max 10000).",
          "minimum": 500,
          "maximum": 10000
        },
        "cursorVoiceControls.autoSend": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable hands-free auto-send after pause (3-5 second pause detection)."
        },
        "cursorVoiceControls.pauseDuration": {
          "type": "number",
          "default": 4000,
          "description": "Pause duration in milliseconds before auto-sending (min 3000, max 5000).",
          "minimum": 3000,
          "maximum": 5000
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  }
}
