{
  "version": "1.0.0",
  "name": "AI Token Request Tracker",
  "description": "Unified tracking of AI requests, token usage, and lookback analysis",
  "last_updated": "2025-12-10T00:00:00Z",
  "lookback_configuration": {
    "enabled": true,
    "lookback_windows": {
      "immediate": {
        "seconds": 60,
        "label": "Last 1 minute",
        "use_case": "Real-time request status"
      },
      "recent": {
        "seconds": 300,
        "label": "Last 5 minutes",
        "use_case": "Recent request history"
      },
      "session": {
        "seconds": 3600,
        "label": "Last 1 hour",
        "use_case": "Current session analysis"
      },
      "daily": {
        "seconds": 86400,
        "label": "Last 24 hours",
        "use_case": "Daily usage summary"
      },
      "weekly": {
        "seconds": 604800,
        "label": "Last 7 days",
        "use_case": "Weekly trends"
      }
    }
  },
  "token_budgets": {
    "github_copilot": {
      "daily_limit": 1000000,
      "monthly_limit": 10000000,
      "current_used_today": 0,
      "current_used_month": 0,
      "warning_threshold": 0.8
    },
    "llama3.2:3b": {
      "daily_limit": 999999999,
      "monthly_limit": 999999999,
      "current_used_today": 0,
      "current_used_month": 0,
      "warning_threshold": 0.9
    },
    "azure_ai": {
      "daily_limit": 500000,
      "monthly_limit": 5000000,
      "current_used_today": 0,
      "current_used_month": 0,
      "warning_threshold": 0.8
    }
  },
  "request_tracking": {
    "enabled": true,
    "retention_days": 90,
    "storage_location": ".lumina/logs/ai_requests/",
    "indexed_by": [
      "request_id",
      "timestamp",
      "agent",
      "status",
      "tokens_used"
    ]
  },
  "agents_tracked": [
    "kilo_code",
    "github_copilot",
    "llama3.2:3b",
    "continue",
    "cline",
    "jarvis",
    "lumina",
    "r5_context_matrix",
    "jedi_council"
  ],
  "master_padawan_learning": {
    "enabled": true,
    "description": "Integrate token tracking with Master/Padawan learner system",
    "master_mode": {
      "role": "Master - Teaching Agent",
      "tracks": [
        "instruction_tokens",
        "explanation_tokens",
        "pattern_teaching_tokens"
      ],
      "token_class": "teaching",
      "learning_objective": "Transfer knowledge to Padawan agents",
      "token_multiplier": 0.5
    },
    "padawan_mode": {
      "role": "Padawan - Learning Agent",
      "tracks": [
        "learning_tokens",
        "practice_tokens",
        "pattern_adoption_tokens"
      ],
      "token_class": "learning",
      "learning_objective": "Adopt and apply Master teachings",
      "token_multiplier": 1.0
    },
    "session_classification": {
      "teaching_session": {
        "description": "Master explains patterns/concepts to Padawan",
        "token_tracking": "teaching",
        "lookback_window": "session"
      },
      "learning_session": {
        "description": "Padawan learns from Master teachings",
        "token_tracking": "learning",
        "lookback_window": "session"
      },
      "practice_session": {
        "description": "Padawan practices with Master oversight",
        "token_tracking": "practice",
        "lookback_window": "daily"
      },
      "mastery_validation": {
        "description": "Master validates Padawan mastery and promotes to independent",
        "token_tracking": "validation",
        "lookback_window": "weekly"
      }
    }
  },
  "rearview_logic": {
    "enabled": true,
    "lookback_strategy": "sliding_window",
    "operations": {
      "get_recent_requests": {
        "description": "Get requests from last N seconds",
        "parameters": [
          "window_seconds"
        ],
        "returns": [
          "request_id",
          "agent",
          "tokens_used",
          "status"
        ]
      },
      "get_request_status": {
        "description": "Get current status of specific request",
        "parameters": [
          "request_id"
        ],
        "returns": [
          "status",
          "tokens_used",
          "result",
          "error"
        ]
      },
      "analyze_token_usage": {
        "description": "Analyze token usage patterns",
        "parameters": [
          "window",
          "agent"
        ],
        "returns": [
          "total_tokens",
          "avg_per_request",
          "peak_usage"
        ]
      },
      "check_budget_health": {
        "description": "Check if approaching token limits",
        "parameters": [
          "provider"
        ],
        "returns": [
          "used_percent",
          "remaining",
          "warning_level"
        ]
      },
      "get_failed_requests": {
        "description": "Get requests that failed in lookback window",
        "parameters": [
          "window_seconds"
        ],
        "returns": [
          "request_ids",
          "failure_reasons",
          "retry_status"
        ]
      }
    }
  },
  "metrics": {
    "total_requests": 0,
    "successful_requests": 0,
    "failed_requests": 0,
    "total_tokens_used": 0,
    "avg_tokens_per_request": 0,
    "success_rate": 1.0,
    "last_request_timestamp": null
  },
  "emergency_mode": true,
  "local_ai_only": true,
  "cloud_apis_blocked": true,
  "cost_control_active": true
}