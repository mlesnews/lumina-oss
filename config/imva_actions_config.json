{
  "version": "1.0.0",
  "description": "IMVA Actions and Animations Configuration",
  "last_updated": "2026-01-15",
  "actions": {
    "idle": {
      "name": "Idle",
      "description": "Standing idle animation",
      "type": "state",
      "animation": "breathing",
      "duration": "continuous",
      "variants": [
        "idle_standard",
        "idle_alert",
        "idle_relaxed"
      ]
    },
    "walking": {
      "name": "Walking",
      "description": "Walking animation",
      "type": "movement",
      "animation": "walk_cycle",
      "duration": "continuous",
      "speed": "normal"
    },
    "flying": {
      "name": "Flying",
      "description": "Flight animation with repulsors",
      "type": "movement",
      "animation": "flight",
      "duration": "continuous",
      "requires_armor": true,
      "effects": [
        "repulsor_glow",
        "trail_effect"
      ]
    },
    "suit_up": {
      "name": "Suit Up",
      "description": "Armor deployment sequence",
      "type": "transformation",
      "animation": "suit_up_sequence",
      "duration": "3-5 seconds",
      "requires_tony": true,
      "variants": {
        "briefcase": "briefcase_deployment",
        "ring": "ring_deployment",
        "autonomous": "autonomous_assembly",
        "nanotech": "nanotech_deployment"
      }
    },
    "suit_down": {
      "name": "Suit Down",
      "description": "Armor removal sequence",
      "type": "transformation",
      "animation": "suit_down_sequence",
      "duration": "3-5 seconds",
      "requires_armor": true
    },
    "repulsor_blast": {
      "name": "Repulsor Blast",
      "description": "Firing repulsor beams",
      "type": "combat",
      "animation": "repulsor_charge_and_fire",
      "duration": "1-2 seconds",
      "requires_armor": true,
      "effects": [
        "energy_charge",
        "beam_effect",
        "muzzle_flash"
      ]
    },
    "unibeam": {
      "name": "Unibeam",
      "description": "Chest arc reactor beam",
      "type": "combat",
      "animation": "unibeam_charge_and_fire",
      "duration": "2-3 seconds",
      "requires_armor": true,
      "effects": [
        "reactor_charge",
        "beam_effect",
        "screen_flash"
      ]
    },
    "landing": {
      "name": "Landing",
      "description": "Landing from flight",
      "type": "movement",
      "animation": "landing_sequence",
      "duration": "1-2 seconds",
      "requires_armor": true,
      "effects": [
        "impact_effect",
        "repulsor_cutoff"
      ]
    },
    "working": {
      "name": "Working",
      "description": "Working on something (holograms, tools)",
      "type": "activity",
      "animation": "working_animation",
      "duration": "continuous",
      "effects": [
        "hologram_overlay",
        "tool_effects"
      ]
    },
    "thinking": {
      "name": "Thinking",
      "description": "Deep thought pose",
      "type": "activity",
      "animation": "thinking_pose",
      "duration": "continuous",
      "effects": [
        "hud_overlay"
      ]
    },
    "celebrating": {
      "name": "Celebrating",
      "description": "Victory celebration",
      "type": "emotion",
      "animation": "celebration",
      "duration": "3-5 seconds",
      "effects": [
        "confetti",
        "sparkles"
      ]
    },
    "damaged": {
      "name": "Damaged",
      "description": "Armor damage state",
      "type": "state",
      "animation": "damaged_idle",
      "duration": "continuous",
      "requires_armor": true,
      "effects": [
        "sparks",
        "smoke",
        "flickering"
      ]
    },
    "sleeping": {
      "name": "Sleeping",
      "description": "Resting/sleeping state",
      "type": "state",
      "animation": "sleeping",
      "duration": "continuous",
      "effects": [
        "dimmed_lights",
        "slow_breathing"
      ]
    },
    "notifying": {
      "name": "Notifying",
      "description": "Notification alert",
      "type": "alert",
      "animation": "notification_pulse",
      "duration": "2-3 seconds",
      "effects": [
        "pulse_effect",
        "alert_glow"
      ]
    },
    "scanning": {
      "name": "Scanning",
      "description": "Environmental scan",
      "type": "activity",
      "animation": "scanning_animation",
      "duration": "3-5 seconds",
      "requires_armor": true,
      "effects": [
        "scan_lines",
        "hud_overlay"
      ]
    },
    "combat_stance": {
      "name": "Combat Stance",
      "description": "Ready for combat",
      "type": "combat",
      "animation": "combat_ready",
      "duration": "continuous",
      "requires_armor": true,
      "effects": [
        "weapons_charged",
        "alert_glow"
      ]
    },
    "pointing": {
      "name": "Pointing",
      "description": "Pointing gesture",
      "type": "gesture",
      "animation": "point",
      "duration": "2-3 seconds"
    },
    "thumbs_up": {
      "name": "Thumbs Up",
      "description": "Approval gesture",
      "type": "gesture",
      "animation": "thumbs_up",
      "duration": "2-3 seconds"
    },
    "wave": {
      "name": "Wave",
      "description": "Waving gesture",
      "type": "gesture",
      "animation": "wave",
      "duration": "2-3 seconds"
    }
  },
  "action_categories": {
    "movement": ["walking", "flying", "landing"],
    "combat": ["repulsor_blast", "unibeam", "combat_stance"],
    "transformation": ["suit_up", "suit_down"],
    "activity": ["working", "thinking", "scanning"],
    "emotion": ["celebrating"],
    "gesture": ["pointing", "thumbs_up", "wave"],
    "state": ["idle", "sleeping", "damaged", "notifying"]
  },
  "action_requirements": {
    "requires_armor": [
      "flying",
      "repulsor_blast",
      "unibeam",
      "landing",
      "scanning",
      "combat_stance",
      "suit_down",
      "damaged"
    ],
    "requires_tony": [
      "suit_up"
    ],
    "works_with_both": [
      "idle",
      "walking",
      "working",
      "thinking",
      "celebrating",
      "sleeping",
      "notifying",
      "pointing",
      "thumbs_up",
      "wave"
    ]
  }
}
