{
  "version": "1.0.0",
  "name": "Lumina IDE Integration",
  "description": "Lumina ecosystem integration with all IDEs and coding assistants - @Peak required",
  "last_updated": "2024-12-19",
  "lumina": {
    "ecosystem": true,
    "enabled": true,
    "required": true,
    "extensions_integration": "config/lumina_extensions_integration.json",
    "content_index": "config/lumina_jarvis_content_index.json"
  },
  "ide_integrations": {
    "cursor": {
      "enabled": true,
      "required": true,
      "adapter_port": 8083,
      "integrations": {
        "r5_system": true,
        "droid_actor_system": true,
        "v3_verification": true,
        "helpdesk": true,
        "jarvis_helpdesk_integration": true,
        "peak_patterns": true,
        "watcher_uatu": true
      },
      "features": {
        "life_coach": true,
        "voice_communication": true,
        "content_indexing": true,
        "extension_management": true,
        "workflow_orchestration": true
      },
      "peak_required": true
    },
    "vscode": {
      "enabled": true,
      "required": true,
      "adapter_port": 8082,
      "integrations": {
        "r5_system": true,
        "droid_actor_system": true,
        "v3_verification": true,
        "helpdesk": true,
        "jarvis_helpdesk_integration": true,
        "peak_patterns": true,
        "watcher_uatu": true
      },
      "features": {
        "life_coach": true,
        "voice_communication": true,
        "content_indexing": true,
        "extension_management": true,
        "workflow_orchestration": true
      },
      "peak_required": true
    },
    "abacus": {
      "enabled": true,
      "required": true,
      "adapter_port": 8084,
      "integrations": {
        "r5_system": true,
        "droid_actor_system": true,
        "v3_verification": true,
        "helpdesk": true,
        "jarvis_helpdesk_integration": true,
        "peak_patterns": true,
        "watcher_uatu": true
      },
      "features": {
        "life_coach": true,
        "voice_communication": true,
        "content_indexing": true,
        "extension_management": true,
        "workflow_orchestration": true
      },
      "peak_required": true
    }
  },
  "assistant_integrations": {
    "kilo_code": {
      "enabled": true,
      "required": true,
      "endpoint": "http://localhost:8080/assistants/kilo_code",
      "integrations": {
        "r5_system": true,
        "droid_actor_system": true,
        "v3_verification": true,
        "helpdesk": true,
        "jarvis_helpdesk_integration": true,
        "peak_patterns": true,
        "watcher_uatu": true
      },
      "features": {
        "life_coach": true,
        "voice_communication": true,
        "content_indexing": true,
        "extension_management": true,
        "workflow_orchestration": true
      },
      "peak_required": true,
      "peak_enforcement": "strict"
    },
    "continue": {
      "enabled": true,
      "required": false,
      "endpoint": "http://localhost:8080/assistants/continue",
      "integrations": {
        "r5_system": false,
        "droid_actor_system": false,
        "v3_verification": true,
        "helpdesk": false,
        "jarvis_helpdesk_integration": 0.85,
        "peak_patterns": false,
        "watcher_uatu": false
      },
      "peak_required": false
    },
    "cline": {
      "enabled": true,
      "required": false,
      "endpoint": "http://localhost:8080/assistants/cline",
      "integrations": {
        "r5_system": false,
        "droid_actor_system": false,
        "v3_verification": true,
        "helpdesk": false,
        "jarvis_helpdesk_integration": 0.85,
        "peak_patterns": false,
        "watcher_uatu": false
      },
      "peak_required": false
    }
  },
  "extensions": {
    "r5_system": {
      "enabled": true,
      "required": true,
      "api_endpoint": "http://localhost:8000/r5",
      "module": "scripts/python/r5_living_context_matrix.py",
      "peak_integration": true
    },
    "droid_actor_system": {
      "enabled": true,
      "required": true,
      "module": "scripts/python/droid_actor_system.py",
      "peak_integration": true
    },
    "v3_verification": {
      "enabled": true,
      "required": true,
      "module": "scripts/python/v3_verification.py",
      "peak_integration": true
    },
    "helpdesk": {
      "enabled": true,
      "required": true,
      "coordinator": "C-3PO",
      "escalation_path": "C-3PO → JARVIS",
      "peak_integration": true
    },
    "jarvis_helpdesk_integration": {
      "enabled": true,
      "required": true,
      "module": "scripts/python/jarvis_helpdesk_integration.py",
      "peak_integration": true
    }
  },
  "peak_enforcement": {
    "required": true,
    "enforcement_level": "strict",
    "validation": true,
    "block_if_missing": true,
    "applies_to": [
      "kilo_code",
      "all_ide_integrations",
      "all_lumina_extensions"
    ]
  }
}