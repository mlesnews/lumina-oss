{
  "version": "1.0.0",
  "description": "@FRB Battleground Sandbox - Full-Robust-Battleground AI Model Testing Environment",
  "last_updated": "2026-01-13",
  "created_by": "LUMINA Collective",
  
  "frb_definition": {
    "tag": "@FRB",
    "full_name": "Full-Robust-Battleground",
    "aliases": ["#frb", "@battleground", "@sandbox", "#SNDBX"],
    "motto": "Test everything. Trust nothing. Validate always.",
    "philosophy": "AI models must prove themselves in battle before deployment"
  },

  "sandbox_environment": {
    "enabled": true,
    "isolated": true,
    "reset_on_exit": false,
    "data_path": "data/frb_battleground",
    "logs_path": "logs/frb_battleground"
  },

  "azure_ai_labs_integration": {
    "enabled": true,
    "extension_id": "ms-azure.azure-ai",
    "services": {
      "azure_openai": {
        "enabled": true,
        "endpoint": "${AZURE_OPENAI_ENDPOINT}",
        "api_key_secret": "azure-openai-api-key",
        "deployments": {
          "gpt4o": {
            "model": "gpt-4o",
            "deployment_name": "gpt-4o-deployment",
            "max_tokens": 128000,
            "status": "available"
          },
          "gpt4o_mini": {
            "model": "gpt-4o-mini",
            "deployment_name": "gpt-4o-mini-deployment",
            "max_tokens": 128000,
            "status": "available"
          },
          "o1_preview": {
            "model": "o1-preview",
            "deployment_name": "o1-preview-deployment",
            "max_tokens": 128000,
            "status": "available"
          },
          "o1_mini": {
            "model": "o1-mini",
            "deployment_name": "o1-mini-deployment",
            "max_tokens": 128000,
            "status": "available"
          }
        }
      },
      "azure_ml": {
        "enabled": true,
        "workspace": "lumina-ml-workspace",
        "endpoint": "https://ml.azure.com"
      },
      "azure_cognitive": {
        "enabled": true,
        "speech": true,
        "text_analytics": true,
        "computer_vision": true
      }
    }
  },

  "model_registry": {
    "description": "All AI models available for battleground testing",
    "categories": {
      "cloud_providers": {
        "azure_openai": [
          {"name": "gpt-4o", "provider": "azure", "status": "active"},
          {"name": "gpt-4o-mini", "provider": "azure", "status": "active"},
          {"name": "o1-preview", "provider": "azure", "status": "active"},
          {"name": "o1-mini", "provider": "azure", "status": "active"}
        ],
        "anthropic": [
          {"name": "claude-sonnet-4-20250514", "provider": "anthropic", "status": "active"},
          {"name": "claude-3.5-sonnet", "provider": "anthropic", "status": "active"},
          {"name": "claude-3-opus", "provider": "anthropic", "status": "active"}
        ],
        "openai_direct": [
          {"name": "gpt-4o", "provider": "openai", "status": "active"},
          {"name": "gpt-4-turbo", "provider": "openai", "status": "active"},
          {"name": "o1", "provider": "openai", "status": "active"}
        ],
        "google": [
          {"name": "gemini-2.0-flash", "provider": "google", "status": "active"},
          {"name": "gemini-1.5-pro", "provider": "google", "status": "available"}
        ]
      },
      "local_homelab": {
        "kaiju": [
          {"name": "codellama:13b", "endpoint": "http://<NAS_IP>:3001", "status": "active"},
          {"name": "qwen2.5:7b", "endpoint": "http://<NAS_IP>:3001", "status": "available"}
        ],
        "localhost": [
          {"name": "qwen2.5:72b", "endpoint": "http://localhost:11434", "status": "pending_pull"}
        ],
        "nas": [
          {"name": "ollama-nas", "endpoint": "http://<NAS_PRIMARY_IP>:11434", "status": "available"}
        ]
      },
      "iron_legion": {
        "experts": [
          {"name": "expert-code", "endpoint": "http://<NAS_IP>:3001", "specialty": "code"},
          {"name": "expert-docs", "endpoint": "http://<NAS_IP>:3002", "specialty": "documentation"},
          {"name": "expert-analysis", "endpoint": "http://<NAS_IP>:3003", "specialty": "analysis"},
          {"name": "expert-security", "endpoint": "http://<NAS_IP>:3004", "specialty": "security"},
          {"name": "expert-devops", "endpoint": "http://<NAS_IP>:3005", "specialty": "devops"},
          {"name": "expert-data", "endpoint": "http://<NAS_IP>:3006", "specialty": "data"},
          {"name": "expert-architect", "endpoint": "http://<NAS_IP>:3007", "specialty": "architecture"}
        ]
      }
    }
  },

  "battleground_tests": {
    "test_suites": {
      "basic_capability": {
        "description": "Basic model capability tests",
        "tests": [
          "text_generation",
          "code_completion",
          "reasoning",
          "summarization",
          "translation"
        ]
      },
      "performance": {
        "description": "Performance and latency tests",
        "tests": [
          "response_time",
          "tokens_per_second",
          "context_length_handling",
          "concurrent_requests"
        ]
      },
      "quality": {
        "description": "Output quality assessment",
        "tests": [
          "accuracy",
          "coherence",
          "instruction_following",
          "format_compliance"
        ]
      },
      "stress": {
        "description": "Stress testing",
        "tests": [
          "max_context_fill",
          "rapid_fire_requests",
          "edge_case_inputs",
          "error_recovery"
        ]
      },
      "comparison": {
        "description": "A/B model comparison",
        "tests": [
          "side_by_side_generation",
          "blind_evaluation",
          "preference_ranking"
        ]
      }
    }
  },

  "model_swap_configuration": {
    "hot_swap_enabled": true,
    "default_model": "claude-sonnet-4-20250514",
    "fallback_chain": [
      "claude-sonnet-4-20250514",
      "gpt-4o",
      "codellama:13b"
    ],
    "swap_triggers": {
      "on_error": true,
      "on_rate_limit": true,
      "on_timeout": true,
      "manual": true
    },
    "swap_strategies": {
      "round_robin": "Rotate through available models",
      "fallback": "Use next model in fallback chain",
      "load_balanced": "Distribute across healthy models",
      "specialty": "Route to expert model by task type"
    }
  },

  "cursor_integration": {
    "custom_models_sync": true,
    "settings_path": "C:\\Users\\mlesn\\AppData\\Roaming\\Cursor\\User\\settings.json",
    "auto_update_on_test": false,
    "test_before_promote": true
  },

  "vscode_extension_integration": {
    "azure_ai_extension": {
      "id": "ms-azure.azure-ai",
      "auto_configure": true
    },
    "continue_extension": {
      "id": "Continue.continue",
      "config_path": ".continue/config.json",
      "auto_sync": true
    },
    "github_copilot": {
      "id": "GitHub.copilot",
      "comparison_mode": true
    }
  },

  "reporting": {
    "enabled": true,
    "output_path": "data/frb_battleground/reports",
    "formats": ["json", "markdown", "html"],
    "metrics": [
      "model_performance",
      "test_results",
      "comparison_scores",
      "swap_history"
    ]
  },

  "n8n_workflows": {
    "frb_test_runner": {
      "description": "Run FRB test suites on models",
      "trigger": "webhook",
      "status": "pending"
    },
    "model_health_monitor": {
      "description": "Monitor model health and availability",
      "trigger": "schedule",
      "status": "pending"
    },
    "auto_swap_handler": {
      "description": "Handle automatic model swaps on failure",
      "trigger": "webhook",
      "status": "pending"
    }
  }
}
