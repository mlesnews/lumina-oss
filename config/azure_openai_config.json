{
  "version": "1.0.0",
  "name": "Azure OpenAI Service Configuration",
  "description": "Configuration for routing ALL OpenAI requests through Azure OpenAI Service",
  "last_updated": "2025-01-24",
  "enabled": true,
  "enforce_azure_routing": true,
  "block_direct_openai": true,
  
  "azure_openai": {
    "resource_name": "${AZURE_OPENAI_RESOURCE_NAME}",
    "endpoint_template": "https://{resource_name}.openai.azure.com",
    "api_version": "2024-02-15-preview",
    "deployment_name": "${AZURE_OPENAI_DEPLOYMENT_NAME}",
    
    "authentication": {
      "method": "azure_key_vault",
      "vault_name": "jarvis-lumina",
      "vault_url": "https://jarvis-lumina.vault.azure.net/",
      "api_key_secret_name": "azure-openai-api-key",
      "fallback_env_var": "AZURE_OPENAI_API_KEY"
    },
    
    "deployments": {
      "default": {
        "name": "${AZURE_OPENAI_DEPLOYMENT_NAME}",
        "model": "gpt-4",
        "description": "Default GPT-4 deployment"
      },
      "gpt4": {
        "name": "${AZURE_OPENAI_DEPLOYMENT_NAME_GPT4}",
        "model": "gpt-4",
        "description": "GPT-4 deployment"
      },
      "gpt4_turbo": {
        "name": "${AZURE_OPENAI_DEPLOYMENT_NAME_GPT4_TURBO}",
        "model": "gpt-4-turbo",
        "description": "GPT-4 Turbo deployment"
      },
      "gpt35": {
        "name": "${AZURE_OPENAI_DEPLOYMENT_NAME_GPT35}",
        "model": "gpt-35-turbo",
        "description": "GPT-3.5 Turbo deployment"
      },
      "tts": {
        "name": "${AZURE_OPENAI_DEPLOYMENT_NAME_TTS}",
        "model": "tts-1",
        "description": "Text-to-Speech deployment",
        "endpoint": "/audio/speech"
      },
      "embeddings": {
        "name": "${AZURE_OPENAI_DEPLOYMENT_NAME_EMBEDDINGS}",
        "model": "text-embedding-ada-002",
        "description": "Embeddings deployment",
        "endpoint": "/embeddings"
      }
    },
    
    "endpoints": {
      "chat_completions": "/openai/deployments/{deployment_name}/chat/completions",
      "completions": "/openai/deployments/{deployment_name}/completions",
      "embeddings": "/openai/deployments/{deployment_name}/embeddings",
      "audio_speech": "/openai/deployments/{deployment_name}/audio/speech",
      "audio_transcriptions": "/openai/deployments/{deployment_name}/audio/transcriptions",
      "audio_translations": "/openai/deployments/{deployment_name}/audio/translations"
    },
    
    "default_parameters": {
      "temperature": 0.7,
      "max_tokens": 4096,
      "top_p": 1.0,
      "frequency_penalty": 0.0,
      "presence_penalty": 0.0
    },
    
    "timeouts": {
      "connect": 30,
      "read": 300,
      "write": 60
    },
    
    "retry": {
      "max_retries": 3,
      "backoff_factor": 2.0,
      "retryable_status_codes": [429, 500, 502, 503, 504]
    }
  },
  
  "migration": {
    "status": "in_progress",
    "direct_openai_blocked": true,
    "azure_openai_required": true,
    "migration_date": "2025-01-24",
    "notes": "All OpenAI requests must route through Azure OpenAI Service for security, compliance, and cost management"
  },
  
  "monitoring": {
    "enabled": true,
    "log_all_requests": true,
    "track_usage": true,
    "track_costs": true,
    "alert_on_direct_openai_usage": true
  },
  
  "documentation": {
    "setup_guide": "docs/system/AZURE_OPENAI_SETUP.md",
    "azure_portal": "https://portal.azure.com",
    "azure_openai_docs": "https://learn.microsoft.com/azure/ai-services/openai/",
    "key_vault_setup": "docs/system/AZURE_SETUP_GUIDE.md"
  }
}