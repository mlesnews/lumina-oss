{
  "_meta": {
    "description": "Per-character/session tool allowlists and denylists for Lumina agents",
    "version": "1.0.0",
    "updated_at": "2026-02-17",
    "reference": "docs/system/OPENCLAW_UNIQUE_FEATURES_AND_LUMINA_FIT.md (Sandbox per session)",
    "notes": "JARVIS = full access. Droids get domain-scoped tools. @MARVIN = read/review/audit only. @HK-47 = security tools + read."
  },
  "characters": {
    "jarvis": {
      "description": "JARVIS — CTO, full system access",
      "allowlist": ["*"],
      "denylist": []
    },
    "marvin": {
      "description": "@MARVIN — Internal COMPUSEC officer, read/review/audit only",
      "allowlist": [
        "read_file",
        "search_files",
        "grep",
        "list_directory",
        "git_log",
        "git_diff",
        "git_status",
        "doctor",
        "run_audit",
        "check_config"
      ],
      "denylist": [
        "write_file",
        "delete_file",
        "execute_command",
        "git_push",
        "git_commit",
        "deploy"
      ]
    },
    "hk47": {
