{
  "proton_family_integration": {
    "name": "Proton Family Subscription Integration",
    "version": "1.0.0",
    "description": "Complete integration of Proton family products for secure remote work",
    "created_at": "2026-01-06",
    "tags": ["@proton", "#protondrive", "#protonvpn", "#protonmail", "#protoncalendar", "#protonpass"],
    "status": "active",
    "subscription": {
      "type": "proton_family",
      "status": "active",
      "features": [
        "protondrive",
        "protonvpn",
        "protonmail",
        "protoncalendar",
        "protonpass",
        "proton_sentinel"
      ]
    },
    "protondrive": {
      "enabled": true,
      "priority": 1,
      "description": "Primary encrypted cloud storage for sensitive files and remote work",
      "encryption": "end-to-end",
      "sync_path": "N:\\cloud_storage_aggregated\\protondrive",
      "dsm_cloud_sync": {
        "enabled": true,
        "method": "webdav",
        "webdav_url": "https://drive.proton.me",
        "selective_sync": true
      },
      "rclone_integration": {
        "enabled": true,
        "remote_name": "protondrive",
        "config_path": "config/rclone/rclone.conf"
      },
      "sync_directories": [
        "my_projects",
        "Documents",
        "config",
        "scripts"
      ],
      "exclude_patterns": [
        "**/node_modules/**",
        "**/.git/objects/**",
        "**/venv/**",
        "**/__pycache__/**",
        "**/data/large/**",
        "**/secrets/**"
      ],
      "authentication": {
        "method": "oauth2",
        "credentials_storage": "azure_key_vault",
        "secrets": [
          "proton-account-username",
          "proton-account-password",
          "proton-api-key"
        ]
      }
    },
    "protonvpn": {
      "enabled": true,
      "description": "VPN service for secure remote access to homelab",
      "auto_connect": true,
      "preferred_server": "fastest",
      "kill_switch": true,
      "secure_core": true,
      "net_shield": true,
      "vpn_required_for": [
        "sensitive_config_files",
        "encrypted_data",
        "nas_access",
        "homelab_services"
      ],
      "integration": {
        "windows_client": true,
        "cli_tools": true,
        "api_access": true
      },
      "credentials": {
        "storage": "azure_key_vault",
        "secrets": [
          "protonvpn-username",
          "protonvpn-password"
        ]
      }
    },
    "protonmail": {
      "enabled": true,
      "description": "Email service with end-to-end encryption",
      "bridge_required": true,
      "bridge_config": {
        "enabled": true,
        "imap_port": 1143,
        "smtp_port": 1025,
        "auto_start": true
      },
      "nas_integration": {
        "enabled": true,
        "config_file": "config/outlook/hybrid_email_config.json",
        "mail_hub": "nas_email_hub"
      },
      "sync_settings": {
        "sync_all_mail": false,
        "sync_recent_only": true,
        "days_to_sync": 30
      },
      "credentials": {
        "storage": "azure_key_vault",
        "secrets": [
          "protonmail-username",
          "protonmail-password",
          "protonmail-bridge-password"
        ]
      }
    },
    "protoncalendar": {
      "enabled": true,
      "description": "Encrypted calendar integration",
      "sync_enabled": true,
      "caldav_sync": true,
      "integration": {
        "outlook": true,
        "google_calendar": false,
        "ical_export": true
      },
      "credentials": {
        "storage": "azure_key_vault",
        "secrets": [
          "protoncalendar-username",
          "protoncalendar-password"
        ]
      }
    },
    "protonpass": {
      "enabled": true,
      "description": "Password manager integration",
      "vault_sync": true,
      "integration": {
        "browser_extensions": true,
        "mobile_apps": true,
        "api_access": true
      },
      "credentials": {
        "storage": "azure_key_vault",
        "secrets": [
          "protonpass-username",
          "protonpass-password",
          "protonpass-vault-key"
        ]
      }
    },
    "remote_work_scenarios": {
      "with_vpn": {
        "enabled": true,
        "vpn_provider": "protonvpn",
        "description": "Secure remote access with VPN",
        "access_methods": [
          "protondrive",
          "nas_direct_access",
          "homelab_services"
        ],
        "encryption": "required",
        "preferred_provider": "protondrive"
      },
      "without_vpn": {
        "enabled": true,
        "description": "Remote access without VPN (less sensitive files only)",
        "access_methods": [
          "dropbox",
          "onedrive"
        ],
        "excluded_methods": [
          "protondrive",
          "nas_direct_access"
        ],
        "sensitive_files_excluded": true,
        "encryption": "recommended"
      }
    },
    "sync_strategy": {
      "lan_access": {
        "mode": "full",
        "location": "N:\\",
        "description": "Full access to all data on NAS via N: drive",
        "performance": "maximum"
      },
      "remote_with_vpn": {
        "mode": "selective",
        "vpn_provider": "protonvpn",
        "sync_providers": ["protondrive"],
        "description": "Selective sync via ProtonVPN for secure access",
        "encryption": "required"
      },
      "remote_without_vpn": {
        "mode": "selective",
        "sync_providers": ["dropbox", "onedrive"],
        "description": "Selective sync without VPN",
        "sensitive_files_excluded": true
      }
    },
    "documentation": {
      "setup_guide": "docs/system/PROTON_FAMILY_INTEGRATION.md",
      "remote_work_guide": "docs/system/REMOTE_WORK_SETUP.md",
      "vpn_setup": "docs/system/PROTONVPN_SETUP.md"
    },
    "updated_at": "2026-01-06T02:00:00.000000"
  }
}
