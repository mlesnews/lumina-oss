        "method": "SSH tunnel"
      }
    },
    "3002": {
      "name": "KAIJU Iron Legion - Mark II",
      "host": "<NAS_IP>",
      "service": "Iron Legion - Llama 3.2 11B",
      "status": "available",
      "purpose": "Secondary general purpose model"
    },
    "3003": {
      "name": "KAIJU Iron Legion - Mark III",
      "host": "<NAS_IP>",
      "service": "Iron Legion - Qwen 2.5 Coder 1.5B",
      "status": "available",
      "purpose": "Lightweight quick model"
    }
  },
  "port_forwarding": {
    "11435": {
      "name": "ULTRON Cursor Integration",
      "source": "localhost:11435",
