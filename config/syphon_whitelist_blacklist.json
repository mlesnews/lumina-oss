{
    "_metadata": {
        "system": "LUMINA",
        "purpose": "SYPHON white/black-listing strategies for Cursor IDE and VS Code",
        "description": "Defines files, patterns, and directories to include/exclude from search, AI context, and SYPHON operations",
        "version": "1.0",
        "last_updated": "2026-01-09"
    },
    "syphon": {
        "description": "SYPHON = grep alias - Lower ranked synonym for grep pattern matching",
        "precedence": 2,
        "alias_of": "@grep",
        "context_weight": 0.8,
        "ai_weight": 0.8,
        "human_weight": 0.2
    },
    "whitelist": {
        "description": "Files/patterns to ALWAYS include in SYPHON operations",
        "patterns": [
            "**/scripts/python/**/*.py",
            "**/config/**/*.json",
            "**/docs/**/*.md",
            "**/.cursorrules",
            "**/data/todo/**/*.json",
            "**/data/system/**/*.json",
            "**/data/god_loop/**/*.json",
            "**/data/gitlens_followup_automation/**/*.json",
            "**/data/retry_manager_diagnostics/**/*.json",
            "**/data/email_analysis/**/*.json",
            "**/data/email_filtered/**/*.json",
            "**/data/email_syphon/**/*.json",
            "**/data/daily_work_cycles/**/*.json",
            "**/data/daily_work_cycles/**/*.md",
            "**/data/cursor_connection_health/**/*.json",
            "**/data/script_consolidation/**/*.json",
            "**/data/star_trek_first_contact/**/*.json",
            "**/data/starfleet_first_contact/**/*.json",
            "**/data/youtube_fetch_results/**/*.json",
            "**/docker/**/*.py",
            "**/docker/**/*.yml",
            "**/docker/**/*.yaml",
            "**/docker/**/*.md",
            "**/docker/**/*.sh",
            "**/docker/**/*.ps1"
        ],
        "directories": [
            "scripts/python",
            "config",
            "docs",
            "docker",
            "data/todo",
            "data/system",
            "data/god_loop",
            "data/gitlens_followup_automation",
            "data/retry_manager_diagnostics",
            "data/email_analysis",
            "data/email_filtered",
            "data/email_syphon",
            "data/daily_work_cycles",
            "data/cursor_connection_health",
            "data/script_consolidation",
            "data/star_trek_first_contact",
            "data/starfleet_first_contact",
            "data/youtube_fetch_results"
        ],
        "file_extensions": [
            ".py",
            ".json",
            ".md",
            ".yml",
            ".yaml",
            ".sh",
            ".ps1",
            ".txt"
        ]
    },
    "blacklist": {
        "description": "Files/patterns to ALWAYS exclude from SYPHON operations",
        "patterns": [
            "**/node_modules/**",
            "**/__pycache__/**",
            "**/*.pyc",
            "**/.pytest_cache/**",
            "**/venv/**",
            "**/.venv/**",
            "**/env/**",
            "**/.env",
            "**/dist/**",
            "**/build/**",
            "**/*.egg-info/**",
            "**/.mypy_cache/**",
            "**/.ruff_cache/**",
            "**/data/local_backup/**",
            "**/data/**/*.encrypted",
            "**/archive/**",
            "**/certificates/**",
            "**/HKLM/**",
            "**/.cursor/**",
            "**/.git/**",
            "**/.DS_Store",
            "**/Thumbs.db",
            "**/*.log",
            "**/*.tmp",
            "**/*.temp",
            "**/*.bak",
            "**/*.backup",
            "**/*.swp",
            "**/*.swo",
            "**/*~"
        ],
        "directories": [
            "node_modules",
            "__pycache__",
            ".pytest_cache",
            "venv",
            ".venv",
            "env",
            "dist",
            "build",
            ".mypy_cache",
            ".ruff_cache",
            "data/local_backup",
            "archive",
            "certificates",
            "HKLM",
            ".cursor",
            ".git"
        ],
        "file_extensions": [
            ".pyc",
            ".pyo",
            ".pyd",
            ".encrypted",
            ".log",
            ".tmp",
            ".temp",
            ".bak",
            ".backup",
            ".swp",
            ".swo"
        ]
    },
    "ai_context": {
        "description": "SYPHON whitelist/blacklist specifically for AI context in Cursor IDE",
        "whitelist": {
            "patterns": [
                "**/scripts/python/**/*.py",
                "**/config/**/*.json",
                "**/docs/**/*.md",
                "**/.cursorrules",
                "**/data/todo/**/*.json",
                "**/data/system/**/*.json"
            ],
            "max_files": 50,
            "max_size_bytes": 1000000
        },
        "blacklist": {
            "patterns": [
                "**/node_modules/**",
                "**/__pycache__/**",
                "**/venv/**",
                "**/data/local_backup/**",
                "**/archive/**",
                "**/.git/**"
            ]
        }
    },
    "search": {
        "description": "SYPHON whitelist/blacklist for file search operations",
        "whitelist": {
            "patterns": [
                "**/scripts/python/**",
                "**/config/**",
                "**/docs/**",
                "**/docker/**",
                "**/data/todo/**",
                "**/data/system/**"
            ]
        },
        "blacklist": {
            "patterns": [
                "**/node_modules/**",
                "**/__pycache__/**",
                "**/venv/**",
                "**/data/local_backup/**",
                "**/archive/**",
                "**/.git/**"
            ]
        }
    },
    "file_watcher": {
        "description": "SYPHON whitelist/blacklist for file watcher (exclude from watching)",
        "blacklist": {
            "patterns": [
                "**/.git/objects/**",
                "**/.git/subtree-cache/**",
                "**/node_modules/**",
                "**/__pycache__/**",
                "**/.pytest_cache/**",
                "**/venv/**",
                "**/data/local_backup/**",
                "**/archive/**",
                "**/.cursor/**"
            ]
        }
    },
    "tags": {
        "description": "SYPHON tag system integration",
        "syphon_tag": "#syphon",
        "grep_tag": "@grep",
        "precedence": {
            "@grep": 1,
            "#syphon": 2
        },
        "usage": {
            "#syphon": "Lower ranked alias for grep. Use when referring to grep as a concept or for lower priority pattern searches.",
            "@grep": "Primary pattern search tool. Use for actual grep operations. Highest precedence in tag hierarchy."
        }
    },
    "integration": {
        "description": "Integration with Cursor IDE and VS Code settings",
        "vscode_settings": ".vscode/settings.json",
        "cursor_settings": ".cursor/settings.json",
        "cursorrules": ".cursorrules",
        "auto_sync": true,
        "sync_on_change": true
    }
}
