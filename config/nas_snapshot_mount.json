{
  "version": "1.0.0",
  "name": "NAS Snapshot Permanent Mount Configuration",
  "description": "Configuration for permanent Windows network drive mounts to NAS snapshot directories",
  "last_updated": "2026-01-13",
  "nas": {
    "host": "<NAS_PRIMARY_IP>",
    "user": "mlesn",
    "type": "Synology",
    "snapshot_enabled": true
  },
  "mounts": [
    {
      "name": "NAS Snapshot",
      "drive_letter": "S",
      "network_path": "\\\\<NAS_PRIMARY_IP>\\snapshot",
      "local_path": "S:\\",
      "type": "Snapshot Share",
      "persistent": true,
      "auto_mount": true,
      "description": "Primary snapshot share (if enabled on Synology)"
    },
    {
      "name": "Volume1 Snapshot",
      "drive_letter": "T",
      "network_path": "\\\\<NAS_PRIMARY_IP>\\volume1\\@snapshot",
      "local_path": "T:\\",
      "type": "BTRFS Snapshot Directory",
      "persistent": true,
      "auto_mount": false,
      "description": "BTRFS snapshot directory (requires SSH/SMB access)"
    },
    {
      "name": "Backup Snapshot",
      "drive_letter": "U",
      "network_path": "\\\\<NAS_PRIMARY_IP>\\backups\\@snapshot",
      "local_path": "U:\\",
      "type": "Backup Snapshot Directory",
      "persistent": true,
      "auto_mount": false,
      "description": "Backup volume snapshot directory"
    }
  ],
  "snapshot_paths": {
    "synology_default": "/volume1/@snapshot",
    "backup_volume": "/volume1/backups/@snapshot",
    "share_based": "/volume1/snapshot",
    "windows_unc": "\\\\<NAS_PRIMARY_IP>\\snapshot"
  },
  "setup_instructions": {
    "step_1": "Enable Snapshot Replication on Synology NAS",
    "step_2": "Create snapshot share or enable @snapshot directory access via SMB",
    "step_3": "Run: .\\scripts\\nas_snapshot_mount.ps1",
    "step_4": "Verify: .\\scripts\\nas_snapshot_mount.ps1 -Check",
    "step_5": "Mounts persist across reboots (Windows persistent network drives)"
  },
  "verification": {
    "check_mounts": "Get-PSDrive -PSProvider FileSystem | Where-Object { $_.DisplayRoot -like '\\\\<NAS_PRIMARY_IP>\\*' }",
    "test_access": "Test-Path S:\\",
    "list_snapshots": "Get-ChildItem S:\\ -Directory | Select-Object Name, LastWriteTime"
  },
  "notes": [
    "Snapshots are read-only by default",
    "Snapshot directory access requires proper SMB/CIFS permissions",
    "BTRFS @snapshot directories may require SSH access instead of SMB",
    "Use Synology Snapshot Replication app to manage snapshots",
    "Snapshots are typically stored in @snapshot subdirectories"
  ]
}
