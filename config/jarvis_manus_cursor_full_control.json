{
  "version": "1.0.0",
  "name": "JARVIS Full Control of Cursor IDE via MANUS",
  "description": "100% MANUS Control and Visibility with Human Intuitive Smart Keymapping",
  "last_updated": "2026-01-02",
  "goal": "100% MANUS Control and Visibility with Windows Engineering Efficiency",
  "windows_optimization": {
    "enabled": true,
    "use_windows_standard_shortcuts": true,
    "conflict_resolution": "ide_priority",
    "hardware_key_conflicts": {
      "F1": {
        "windows_action": "Help",
        "ide_action": "Command Palette",
        "solution": "Use Ctrl+Shift+P for Command Palette"
      },
      "Alt+F4": {
        "windows_action": "Close Window",
        "ide_action": "Close Editor",
        "solution": "Use Ctrl+W for Close Editor, Ctrl+Shift+W for Close Window"
      },
      "F11": {
        "windows_action": "Browser Full Screen",
        "ide_action": "IDE Full Screen",
        "solution": "Use Ctrl+K Ctrl+Z for Zen Mode"
      }
    }
  },
  "smart_keymapping": {
    "strategy": "human_intuitive",
    "priority_order": [
      "most_common_actions",
      "cursor_specific_features",
      "standard_ide_features",
      "advanced_features"
    ],
    "intuitive_priorities": {
      "1": "Most intuitive - single key or common combination",
      "2": "Moderately intuitive - standard IDE shortcuts",
      "3": "Less intuitive - requires learning"
    }
  },
  "ff_features": {
    "navigation": {
      "enabled": true,
      "features": [
        {
          "id": "quick_open",
          "name": "Quick Open File",
          "shortcut": "Ctrl+P",
          "command": "workbench.action.quickOpen",
          "intuitive_priority": 1,
          "description": "Open file quickly - most common action"
        },
        {
          "id": "command_palette",
          "name": "Command Palette",
          "shortcut": "Ctrl+Shift+P",
          "command": "workbench.action.showCommands",
          "intuitive_priority": 1,
          "description": "Access all commands"
        },
        {
          "id": "go_to_symbol",
          "name": "Go to Symbol in File",
          "shortcut": "Ctrl+Shift+O",
          "command": "workbench.action.gotoSymbol",
          "intuitive_priority": 2,
          "description": "Navigate to symbol in current file"
        },
        {
          "id": "go_to_symbol_workspace",
          "name": "Go to Symbol in Workspace",
          "shortcut": "Ctrl+T",
          "command": "workbench.action.showAllSymbols",
          "intuitive_priority": 2,
          "description": "Navigate to symbol across workspace"
        },
        {
          "id": "go_to_line",
          "name": "Go to Line",
          "shortcut": "Ctrl+G",
          "command": "workbench.action.gotoLine",
          "intuitive_priority": 2,
          "description": "Jump to specific line number"
        }
      ]
    },
    "ai_features": {
      "enabled": true,
      "cursor_specific": true,
      "features": [
        {
          "id": "open_chat",
          "name": "Open Chat",
          "shortcut": "Ctrl+K Ctrl+K",
          "command": "cursor.chat.open",
          "intuitive_priority": 1,
          "description": "Open Cursor AI chat"
        },
        {
          "id": "open_composer",
          "name": "Open Composer",
          "shortcut": "Ctrl+K Ctrl+C",
          "command": "cursor.composer.open",
          "intuitive_priority": 1,
          "description": "Open Cursor AI Composer"
        },
        {
          "id": "inline_edit",
          "name": "Inline Edit",
          "shortcut": "Ctrl+K Ctrl+I",
          "command": "cursor.inlineEdit",
          "intuitive_priority": 1,
          "description": "Start inline AI edit"
        },
        {
          "id": "explain_code",
          "name": "Explain Code",
          "shortcut": "Ctrl+K Ctrl+E",
          "command": "cursor.explain",
          "intuitive_priority": 2,
          "description": "AI explain selected code"
        },
        {
          "id": "refactor_code",
          "name": "Refactor Code",
          "shortcut": "Ctrl+K Ctrl+R",
          "command": "cursor.refactor",
          "intuitive_priority": 2,
          "description": "AI refactor selected code"
        },
        {
          "id": "generate_tests",
          "name": "Generate Tests",
          "shortcut": "Ctrl+K Ctrl+T",
          "command": "cursor.generateTests",
          "intuitive_priority": 2,
          "description": "AI generate tests for code"
        },
        {
          "id": "chat_history",
          "name": "Chat History",
          "shortcut": "Ctrl+K Ctrl+H",
          "command": "cursor.chat.history",
          "intuitive_priority": 2,
          "description": "View chat history"
        }
      ]
    },
    "editing": {
      "enabled": true,
      "features": [
        {
          "id": "save",
          "name": "Save",
          "shortcut": "Ctrl+S",
          "command": "workbench.action.files.save",
          "intuitive_priority": 1,
          "description": "Save current file"
        },
        {
          "id": "save_all",
          "name": "Save All",
          "shortcut": "Ctrl+K S",
          "command": "workbench.action.files.saveAll",
          "intuitive_priority": 2,
          "description": "Save all files"
        },
        {
          "id": "find",
          "name": "Find",
          "shortcut": "Ctrl+F",
          "command": "actions.find",
          "intuitive_priority": 1,
          "description": "Find in file"
        },
        {
          "id": "replace",
          "name": "Replace",
          "shortcut": "Ctrl+H",
          "command": "editor.action.startFindReplaceAction",
          "intuitive_priority": 1,
          "description": "Find and replace in file"
        },
        {
          "id": "find_in_files",
          "name": "Find in Files",
          "shortcut": "Ctrl+Shift+F",
          "command": "workbench.view.search",
          "intuitive_priority": 2,
          "description": "Search across all files"
        },
        {
          "id": "replace_in_files",
          "name": "Replace in Files",
          "shortcut": "Ctrl+Shift+H",
          "command": "workbench.action.replaceInFiles",
          "intuitive_priority": 2,
          "description": "Find and replace across all files"
        }
      ]
    },
    "view": {
      "enabled": true,
      "features": [
        {
          "id": "toggle_sidebar",
          "name": "Toggle Sidebar",
          "shortcut": "Ctrl+B",
          "command": "workbench.action.toggleSidebarVisibility",
          "intuitive_priority": 1,
          "description": "Show/hide sidebar"
        },
        {
          "id": "toggle_terminal",
          "name": "Toggle Terminal",
          "shortcut": "Ctrl+`",
          "command": "workbench.action.terminal.toggleTerminal",
          "intuitive_priority": 1,
          "description": "Show/hide terminal"
        },
        {
          "id": "zen_mode",
          "name": "Zen Mode",
          "shortcut": "Ctrl+K Ctrl+Z",
          "command": "workbench.action.toggleZenMode",
          "intuitive_priority": 2,
          "description": "Distraction-free coding"
        }
      ]
    },
    "debugging": {
      "enabled": true,
      "features": [
        {
          "id": "start_debugging",
          "name": "Start Debugging",
          "shortcut": "F5",
          "command": "workbench.action.debug.start",
          "intuitive_priority": 1,
          "description": "Start debugging session"
        },
        {
          "id": "toggle_breakpoint",
          "name": "Toggle Breakpoint",
          "shortcut": "F9",
          "command": "editor.debug.action.toggleBreakpoint",
          "intuitive_priority": 1,
          "description": "Add/remove breakpoint"
        },
        {
          "id": "step_over",
          "name": "Step Over",
          "shortcut": "F10",
          "command": "workbench.action.debug.stepOver",
          "intuitive_priority": 1,
          "description": "Debug step over"
        },
        {
          "id": "step_into",
          "name": "Step Into",
          "shortcut": "F11",
          "command": "workbench.action.debug.stepInto",
          "intuitive_priority": 1,
          "description": "Debug step into"
        },
        {
          "id": "step_out",
          "name": "Step Out",
          "shortcut": "Shift+F11",
          "command": "workbench.action.debug.stepOut",
          "intuitive_priority": 2,
          "description": "Debug step out"
        }
      ]
    }
  },
  "manus_integration": {
    "enabled": true,
    "control_area": "ide_control",
    "visibility_enabled": true,
    "monitoring_interval": 1.0,
    "action_tracking": true,
    "history_retention": 1000
  },
  "jarvis_integration": {
    "enabled": true,
    "peak_tool_selection": true,
    "agent_management": true,
    "coordination": true
  },
  "tags": [
    "#JARVIS",
    "#MANUS",
    "#CURSOR",
    "#IDE",
    "#KEYBOARD",
    "#SHORTCUTS",
    "#@FF",
    "#WINDOWS",
    "#CONTROL",
    "@JARVIS",
    "@TEAM"
  ]
}
