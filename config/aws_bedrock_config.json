{
  "version": "1.0.0",
  "name": "AWS Bedrock Configuration",
  "description": "Configuration for AWS Bedrock integration with Cursor IDE",
  "last_updated": "2025-01-24",
  "enabled": true,
  
  "aws_bedrock": {
    "region": "${AWS_REGION}",
    "default_region": "us-east-1",
    
    "authentication": {
      "method": "protonpass_azure_vault",
      "priority": "+++++ MEMORY PRIORITY",
      "description": "CRITICAL: ALWAYS use ProtonPass CLI and Azure Key Vault for ALL secrets. NEVER use plain text files.",
      "options": [
        "protonpass_azure_vault",
        "azure_key_vault",
        "protonpass",
        "environment_variables"
      ],
      "credential_manager": {
        "script": "scripts/python/bedrock_credential_manager.py",
        "class": "BedrockCredentialManager",
        "method": "get_credentials"
      },
      "azure_key_vault": {
        "vault_name": "jarvis-lumina",
        "vault_url": "https://jarvis-lumina.vault.azure.net/",
        "secret_names": {
          "access_key_id": "aws-bedrock-access-key-id",
          "secret_access_key": "aws-bedrock-secret-access-key",
          "session_token": "aws-bedrock-session-token",
          "region": "aws-bedrock-region"
        },
        "primary": true
      },
      "protonpass": {
        "cli_command": "protonpass",
        "secret_names": {
          "access_key_id": "aws-bedrock-access-key-id",
          "secret_access_key": "aws-bedrock-secret-access-key",
          "session_token": "aws-bedrock-session-token",
          "region": "aws-bedrock-region"
        },
        "sync_from_azure": true
      },
      "fallback": {
        "env_vars": {
          "access_key_id": "AWS_ACCESS_KEY_ID",
          "secret_access_key": "AWS_SECRET_ACCESS_KEY",
          "session_token": "AWS_SESSION_TOKEN",
          "region": "AWS_REGION"
        },
        "warning": "Only use as last resort - prefer ProtonPass/Azure Vault"
      }
    },
    
    "models": {
      "claude_3_5_sonnet": {
        "model_id": "anthropic.claude-3-5-sonnet-20241022-v2:0",
        "description": "Claude 3.5 Sonnet (latest)",
        "recommended": true,
        "max_tokens": 8192,
        "context_window": 200000
      },
      "claude_3_5_haiku": {
        "model_id": "anthropic.claude-3-5-haiku-20241022-v2:0",
        "description": "Claude 3.5 Haiku (fast, cost-effective)",
        "max_tokens": 8192,
        "context_window": 200000
      },
      "claude_3_sonnet": {
        "model_id": "anthropic.claude-3-sonnet-20240229-v1:0",
        "description": "Claude 3 Sonnet",
        "max_tokens": 4096,
        "context_window": 200000
      },
      "claude_3_opus": {
        "model_id": "anthropic.claude-3-opus-20240229-v1:0",
        "description": "Claude 3 Opus (most capable)",
        "max_tokens": 4096,
        "context_window": 200000
      },
      "claude_3_haiku": {
        "model_id": "anthropic.claude-3-haiku-20240307-v1:0",
        "description": "Claude 3 Haiku (fastest)",
        "max_tokens": 4096,
        "context_window": 200000
      },
      "llama3_1_405b": {
        "model_id": "meta.llama3-1-405b-instruct-v1:0",
        "description": "Llama 3.1 405B Instruct",
        "max_tokens": 8192,
        "context_window": 131072
      },
      "llama3_1_70b": {
        "model_id": "meta.llama3-1-70b-instruct-v1:0",
        "description": "Llama 3.1 70B Instruct",
        "max_tokens": 8192,
        "context_window": 131072
      },
      "llama3_1_8b": {
        "model_id": "meta.llama3-1-8b-instruct-v1:0",
        "description": "Llama 3.1 8B Instruct",
        "max_tokens": 8192,
        "context_window": 131072
      }
    },
    
    "default_model": {
      "model_id": "anthropic.claude-3-5-sonnet-20241022-v2:0",
      "description": "Claude 3.5 Sonnet (recommended)"
    },
    
    "endpoints": {
      "base_url": "https://bedrock-runtime.{region}.amazonaws.com",
      "invoke_model": "/model/{model_id}/invoke",
      "invoke_model_with_response_stream": "/model/{model_id}/invoke-with-response-stream"
    },
    
    "default_parameters": {
      "temperature": 0.7,
      "max_tokens": 4096,
      "top_p": 1.0,
      "top_k": 250
    },
    
    "timeouts": {
      "connect": 30,
      "read": 300,
      "write": 60
    },
    
    "retry": {
      "max_retries": 3,
      "backoff_factor": 2.0,
      "retryable_status_codes": [429, 500, 502, 503, 504, "ThrottlingException", "ServiceQuotaExceededException"]
    }
  },
  
  "cursor_integration": {
    "enabled": true,
    "settings": {
      "provider": "aws-bedrock",
      "region": "${AWS_REGION}",
      "model_id": "anthropic.claude-3-5-sonnet-20241022-v2:0",
      "api_version": "bedrock-2023-05-31",
      "authentication": "aws_credentials"
    },
    "instructions": "Use AWS Bedrock for Claude models. Configure region and credentials in Cursor settings."
  },
  
  "monitoring": {
    "enabled": true,
    "log_all_requests": true,
    "track_usage": true,
    "track_costs": true,
    "cloudwatch_integration": false
  },
  
  "documentation": {
    "setup_guide": "docs/system/AWS_BEDROCK_SETUP.md",
    "aws_console": "https://console.aws.amazon.com/bedrock/",
    "aws_bedrock_docs": "https://docs.aws.amazon.com/bedrock/",
    "cursor_docs": "https://cursor.com/docs"
  }
}