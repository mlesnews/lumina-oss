{
  "conversational_mode": true,
  "preserve_intent": true,
  "allow_informal": true,
  "override_strict_grammar": true,
  "preserve_voice_tone": true,
  "ignore_casual_errors": true,
  "min_confidence": 0.7,
  "auto_apply": false,
  "patterns_to_ignore": [
    "^[A-Z\\s]+$",
    "\\.{3,}",
    "!{2,}"
  ],
  "context_aware": true,
  "description": "JARVIS Grammarly oversight rules for conversational flow"
}
