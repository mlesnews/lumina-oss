{
  "service_bus_config": {
    "version": "1.0.0",
    "last_updated": "2026-01-14",
    "namespace": "jarvis-lumina-bus",
    "fully_qualified_namespace": "jarvis-lumina-bus.servicebus.windows.net",
    "resource_group": "jarvis-lumina-rg",
    "location": "East US 2",
    "connection_string_secret_name": "azure-service-bus-connection-string",
    "topics": {
      "jarvis.workflows": {
        "name": "jarvis.workflows",
        "subscriptions": [
          "workflow-processor",
          "workflow-notifications",
          "workflow-audit"
        ]
      },
      "jarvis.escalations": {
        "name": "jarvis.escalations",
        "subscriptions": [
          "jarvis-escalation-handler",
          "escalation-notifications"
        ]
      },
      "jarvis.intelligence": {
        "name": "jarvis.intelligence",
        "subscriptions": [
          "intelligence-processor",
          "intelligence-feed",
          "intelligence-analytics"
        ]
      },
      "jarvis.responses": {
        "name": "jarvis.responses",
        "subscriptions": [
          "response-handler",
          "response-notifications"
        ]
      },
      "lumina.workflows": {
        "name": "lumina.workflows",
        "subscriptions": [
          "lumina-workflow-processor",
          "workflow-verification",
          "workflow-r5-sync"
        ]
      },
      "lumina.verification": {
        "name": "lumina.verification",
        "subscriptions": [
          "v3-verification-processor",
          "verification-audit"
        ]
      },
      "r5.knowledge": {
        "name": "r5.knowledge",
        "subscriptions": [
          "r5-ingestion-processor",
          "r5-pattern-extractor",
          "r5-search-processor"
        ]
      },
      "helpdesk.coordination": {
        "name": "helpdesk.coordination",
        "subscriptions": [
          "helpdesk-coordinator",
          "droid-assignment",
          "helpdesk-notifications"
        ]
      }
    },
    "queues": {
      "jarvis-escalation-queue": {
        "name": "jarvis-escalation-queue",
        "max_delivery_count": 10,
        "lock_duration_seconds": 120
      },
      "workflow-execution-queue": {
        "name": "workflow-execution-queue",
        "max_delivery_count": 5,
        "lock_duration_seconds": 300
      },
      "r5-ingestion-queue": {
        "name": "r5-ingestion-queue",
        "max_delivery_count": 10,
        "lock_duration_seconds": 60
      },
      "verification-queue": {
        "name": "verification-queue",
        "max_delivery_count": 5,
        "lock_duration_seconds": 120
      },
      "droid-assignment-queue": {
        "name": "droid-assignment-queue",
        "max_delivery_count": 5,
        "lock_duration_seconds": 60
      }
    },
    "retry_policy": {
      "max_retries": 3,
      "initial_delay_seconds": 1,
      "max_delay_seconds": 60,
      "backoff_multiplier": 2.0
    }
  }
}
