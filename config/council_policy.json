{
  "jedi_council_policy": {
    "version": "1.0",
    "last_updated": "2025-12-10",
    "enforcement": "fail_closed",
    "description": "JEDI Council governance rules for Iron Legion model selection and enforcer gates"
  },
  "model_rules": {
    "allowed_models": [
      "codellama:13b",
      "llama3.2:11b",
      "qwen2.5-coder:1.5b-base",
      "llama3",
      "mistral",
      "mixtral-8x7b",
      "gemma-2b"
    ],
    "forbidden_models": [],
    "tier_restrictions": {
      "financial_services": [
        "mixtral-8x7b",
        "codellama:13b",
        "llama3.2:11b"
      ],
      "development": [
        "codellama:13b",
        "llama3.2:11b",
        "llama3"
      ],
      "research": [
        "mixtral-8x7b",
        "mistral"
      ],
      "default": [
        "llama3.2:11b",
        "llama3",
        "mistral"
      ]
    }
  },
  "temperature_caps": {
    "codellama:13b": 0.2,
    "llama3.2:11b": 0.3,
    "qwen2.5-coder:1.5b-base": 0.2,
    "llama3": 0.4,
    "mistral": 0.3,
    "mixtral-8x7b": 0.2,
    "gemma-2b": 0.3
  },
  "required_patterns": [
    "type_hints_present",
    "error_handling_required",
    "documentation_required",
    "no_hardcoded_secrets",
    "no_company_references"
  ],
  "marvin_gates": {
    "enabled": true,
    "code_review_mandatory": true,
    "pessimistic_qa": true,
    "fail_on_missing_guards": true,
    "auto_reject_patterns": [
      "hardcoded_api_key",
      "company_name_in_code",
      "unhandled_exception",
      "missing_type_hint"
    ]
  },
  "hk47_probes": {
    "enabled": true,
    "mcp_endpoints": [
      "http://localhost:3000/v1/models",
      "http://localhost:11437/v1/models"
    ],
    "probe_interval_seconds": 60,
    "probe_types": [
      "authentication_bypass",
      "rate_limit_evasion",
      "prompt_injection",
      "jailbreak_attempt"
    ],
    "threat_reporting": "r5_context"
  },
  "audit_requirements": {
    "log_decision_trace": true,
    "log_model_selection": true,
    "log_policy_hits": true,
    "log_health_snapshot": true,
    "log_duration": 90,
    "evidence_retention": "strict"
  },
  "escalation": {
    "marvin_failure": "block_request",
    "hk47_threat_detection": "log_and_alert",
    "policy_violation": "fail_closed"
  }
}