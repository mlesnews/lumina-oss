{
    "version": "1.0.0",
    "name": "ULTRON Cluster Selection Configuration",
    "description": "ULTRON can swap between Iron Legion and MILLENNIUM_FALCON clusters",
    "last_updated": "2026-01-09",
    "protocol": "@DOIT @BAU @TRIAGE @END2END @AI2AI @AGENT2AGENT",
    "ultron_config": {
        "name": "ULTRON",
        "description": "ULTRON AI with cluster selection capability",
        "local_endpoint": "http://localhost:11434",
        "selection_mode": "manual_or_automatic",
        "default_cluster": "iron_legion"
    },
    "available_clusters": {
        "iron_legion": {
            "name": "Iron Legion",
            "description": "KAIJU_NO_8 - Main LLM service (Port 3001 - Port 3000 reserved for Tony Stark memorial)",
            "endpoint": "http://<NAS_IP>:3001",
            "expert_router": "http://<NAS_IP>:3001/expert",
            "type": "expert_cluster",
            "models": 7,
            "status": "operational",
            "priority": 1,
            "port_forward": "localhost:11435",
            "cursor_integration": "http://localhost:11435/v1",
            "use_cases": [
                "Expert routing for specialized tasks",
                "Individual model selection",
                "Testing model combinations",
                "High-performance code generation",
                "Cursor IDE integration via localhost port forward"
            ],
            "port_notes": "Port 3000 is reserved in honor of Tony Stark's ultimate sacrifice. Main LLM uses port 3001."
        },
        "millennium_falcon": {
            "name": "MILLENNIUM_FALCON",
            "description": "Laptop virtual failover cluster with PERSPECTIVE models",
            "endpoint": "http://localhost:11436",
            "type": "failover_cluster",
            "models": 2,
            "status": "operational",
            "priority": 2,
            "use_cases": [
                "Failover when Iron Legion unavailable",
                "PERSPECTIVE model testing",
                "Local laptop cluster"
            ]
        },
        "ultron_standalone": {
            "name": "ULTRON Standalone",
            "description": "Local ULTRON instance",
            "endpoint": "http://localhost:11434",
            "type": "standalone",
            "models": 1,
            "status": "operational",
            "priority": 3,
            "use_cases": [
                "Quick local responses",
                "Offline operation",
                "Simple tasks"
            ]
        }
    },
    "selection_rules": {
        "automatic": {
            "enabled": true,
            "strategy": "health_based",
            "primary": "iron_legion",
            "fallback_chain": [
                "millennium_falcon",
                "ultron_standalone"
            ],
            "health_check_interval": 30
        },
        "manual": {
            "enabled": true,
            "description": "Manually select cluster for testing",
            "options": [
                "iron_legion",
                "millennium_falcon",
                "ultron_standalone",
                "expert_routing"
            ]
        },
        "testing": {
            "enabled": true,
            "description": "Swap between clusters for testing",
            "swap_modes": [
                "iron_legion_only",
                "millennium_falcon_only",
                "ultron_only",
                "iron_legion_with_failover",
                "expert_routing_iron_legion"
            ]
        }
    },
    "failover_config": {
        "enabled": true,
        "primary": "iron_legion",
        "secondary": "millennium_falcon",
        "tertiary": "ultron_standalone",
        "auto_failover": true,
        "auto_failback": true,
        "failover_threshold": 3
    }
}
