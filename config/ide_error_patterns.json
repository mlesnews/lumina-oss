{
  "version": "1.0.0",
  "name": "IDE Error Patterns Configuration",
  "description": "Patterns in behavior/actions = intent, broken down to basic building blocks",
  "last_updated": "2026-01-02",
  "patterns": {
    "syntax_missing_colon": {
      "pattern_id": "syntax_missing_colon",
      "pattern_name": "Missing Colon",
      "regex": "expected ':'|missing colon|SyntaxError.*:",
      "category": "syntax",
      "intent": "Add missing colon to fix syntax",
      "building_blocks": [
        "detect_missing_colon",
        "locate_line",
        "insert_colon"
      ],
      "fix_strategy": "insert_text",
      "ff_shortcuts": ["F2"],
      "proven": true,
      "success_rate": 0.95
    },
    "type_mismatch": {
      "pattern_id": "type_mismatch",
      "pattern_name": "Type Mismatch",
      "regex": "type.*mismatch|expected.*got|TypeError|Incompatible types",
      "category": "type",
      "intent": "Fix type mismatch",
      "building_blocks": [
        "detect_type_error",
        "identify_expected_type",
        "fix_type"
      ],
      "fix_strategy": "type_fix",
      "ff_shortcuts": ["F12"],
      "proven": true,
      "success_rate": 0.85
    },
    "import_error": {
      "pattern_id": "import_error",
      "pattern_name": "Import Error",
      "regex": "ImportError|ModuleNotFoundError|Cannot find module|import.*not found",
      "category": "import",
      "intent": "Fix missing import",
      "building_blocks": [
        "detect_missing_import",
        "find_module",
        "add_import"
      ],
      "fix_strategy": "add_import",
      "ff_shortcuts": ["Ctrl+Shift+P"],
      "proven": true,
      "success_rate": 0.90
    },
    "undefined_variable": {
      "pattern_id": "undefined_variable",
      "pattern_name": "Undefined Variable",
      "regex": "undefined.*variable|NameError|not defined|Cannot find name",
      "category": "undefined",
      "intent": "Fix undefined variable",
      "building_blocks": [
        "detect_undefined",
        "find_definition",
        "fix_reference"
      ],
      "fix_strategy": "fix_reference",
      "ff_shortcuts": ["F12", "Shift+F12"],
      "proven": true,
      "success_rate": 0.80
    },
    "unused_variable": {
      "pattern_id": "unused_variable",
      "pattern_name": "Unused Variable",
      "regex": "unused.*variable|unused import|assigned.*never used",
      "category": "unused",
      "intent": "Remove or use unused variable",
      "building_blocks": [
        "detect_unused",
        "check_usage",
        "remove_or_fix"
      ],
      "fix_strategy": "remove_unused",
      "ff_shortcuts": ["Ctrl+K Ctrl+X"],
      "proven": true,
      "success_rate": 0.75
    },
    "lint_error": {
      "pattern_id": "lint_error",
      "pattern_name": "Lint Error",
      "regex": "lint|pylint|flake8|mypy|ruff",
      "category": "lint",
      "intent": "Fix linting issue",
      "building_blocks": [
        "detect_lint",
        "identify_rule",
        "apply_fix"
      ],
      "fix_strategy": "lint_fix",
      "ff_shortcuts": ["Ctrl+Alt+F"],
      "proven": true,
      "success_rate": 0.70
    },
    "format_error": {
      "pattern_id": "format_error",
      "pattern_name": "Format Error",
      "regex": "format|indentation|whitespace|trailing.*space",
      "category": "format",
      "intent": "Fix formatting",
      "building_blocks": [
        "detect_format",
        "identify_issue",
        "format_code"
      ],
      "fix_strategy": "format",
      "ff_shortcuts": ["Ctrl+Alt+F", "Ctrl+K Ctrl+F"],
      "proven": true,
      "success_rate": 0.95
    },
    "config_error": {
      "pattern_id": "config_error",
      "pattern_name": "Config Error",
      "regex": "config.*error|configuration.*invalid|settings.*error",
      "category": "config",
      "intent": "Fix configuration",
      "building_blocks": [
        "detect_config_error",
        "validate_config",
        "fix_config"
      ],
      "fix_strategy": "config_fix",
      "ff_shortcuts": ["Ctrl+,"],
      "proven": true,
      "success_rate": 0.80
    },
    "dependency_error": {
      "pattern_id": "dependency_error",
      "pattern_name": "Dependency Error",
      "regex": "dependency|package.*not found|module.*not installed",
      "category": "dependency",
      "intent": "Install missing dependency",
      "building_blocks": [
        "detect_missing_dep",
        "identify_package",
        "install_package"
      ],
      "fix_strategy": "install_dependency",
      "ff_shortcuts": ["Ctrl+`"],
      "proven": true,
      "success_rate": 0.90
    }
  },
  "universal_patterns": {
    "vscode_common": [
      "syntax_missing_colon",
      "type_mismatch",
      "import_error",
      "undefined_variable",
      "unused_variable",
      "format_error"
    ],
    "cursor_ide_specific": [
      "lint_error",
      "format_error",
      "config_error",
      "dependency_error"
    ],
    "shared_common": [
      "syntax_missing_colon",
      "import_error",
      "format_error",
      "dependency_error"
    ]
  },
  "ff_shortcuts": {
    "F2": "Rename Symbol / Quick Edit",
    "F12": "Go to Definition",
    "Shift+F12": "Go to References",
    "Ctrl+Shift+P": "Command Palette",
    "Ctrl+Alt+F": "Format Document",
    "Ctrl+K Ctrl+F": "Format Selection",
    "Ctrl+K Ctrl+X": "Trim Trailing Whitespace",
    "Ctrl+,": "Settings",
    "Ctrl+`": "Toggle Terminal"
  },
  "simulation": {
    "enabled": true,
    "validate_before_apply": true,
    "min_success_rate": 0.75,
    "auto_apply_proven": true
  },
  "_metadata": {
    "documentation": "docs/system/PROACTIVE_IDE_TROUBLESHOOTER.md",
    "script": "scripts/python/jarvis_proactive_ide_troubleshooter.py",
    "tags": ["@CURSOR", "@IDE", "#TROUBLESHOOTING", "#PATTERNS", "#PEAK", "#FF", "#PROACTIVE"]
  }
}
