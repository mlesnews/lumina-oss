{
  "health_checks": {
    "step_progress": {
      "description": "Monitor workflow step completion progress",
      "interval_seconds": 30,
      "alert_threshold": "no_progress_5min"
    },
    "error_rate": {
      "description": "Monitor rate of errors/failures",
      "alert_threshold": "error_rate_10percent"
    },
    "memory_usage": {
      "description": "Monitor memory usage for memory leaks",
      "alert_threshold": "memory_usage_80percent"
    },
    "confidence_distribution": {
      "description": "Monitor confidence score distribution",
      "alert_threshold": "too_many_low_confidence"
    }
  },
  "alert_levels": {
    "info": "Informational - workflow is operating normally",
    "warning": "Attention needed - potential issues detected",
    "error": "Action required - workflow experiencing problems",
    "critical": "Immediate action required - workflow may be failing"
  },
  "heartbeat_config": {
    "enabled": true,
    "interval_seconds": 60,
    "timeout_seconds": 300,
    "failure_action": "log_and_alert"
  }
}