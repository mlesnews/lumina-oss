{
  "version": "1.0.0",
  "name": "IDE Workflow Optimization Configuration",
  "description": "Configuration for optimizing IDE analyst/engineer workflows for @peak @ask per second rate",
  "last_updated": "2025-12-27",
  "target_ask_rate_per_second": 5.0,
  "target_response_time_ms": 2000.0,
  "peak_mode_threshold": 3.0,
  "flow_window_seconds": 60,
  "bottleneck_threshold": 1.0,
  "optimization_modes": {
    "peak": {
      "enabled": true,
      "target_rate": 5.0,
      "flow_priority": "throughput",
      "description": "Maximum throughput mode - prioritize questions per second"
    },
    "balanced": {
      "enabled": true,
      "target_rate": 3.0,
      "flow_priority": "quality",
      "description": "Balanced mode - balance between throughput and quality"
    },
    "quality": {
      "enabled": true,
      "target_rate": 2.0,
      "flow_priority": "quality",
      "description": "Quality mode - prioritize response quality over speed"
    }
  },
  "workflow_phases": {
    "analysis": {
      "target_duration_ms": 5000,
      "optimization_strategies": [
        "Parallel analysis",
        "Cached context",
        "Incremental processing"
      ]
    },
    "question": {
      "target_duration_ms": 2000,
      "optimization_strategies": [
        "Batch questions",
        "Pre-load context",
        "Stream responses",
        "Cache common patterns"
      ]
    },
    "implementation": {
      "target_duration_ms": 10000,
      "optimization_strategies": [
        "Parallel execution",
        "Incremental updates",
        "Background processing"
      ]
    },
    "review": {
      "target_duration_ms": 3000,
      "optimization_strategies": [
        "Automated checks",
        "Parallel review",
        "Template matching"
      ]
    }
  },
  "optimization_strategies": {
    "rate_optimization": {
      "batch_questions": true,
      "preload_context": true,
      "cache_responses": true,
      "parallel_processing": 2,
      "stream_responses": true
    },
    "flow_optimization": {
      "reduce_context_switching": true,
      "pipeline_processing": true,
      "async_operations": true,
      "background_tasks": true
    },
    "quality_optimization": {
      "adaptive_quality": true,
      "quality_vs_speed_tradeoff": 0.7,
      "minimum_quality_threshold": 0.8
    }
  },
  "integration": {
    "cursor_agent_modes": true,
    "cursor_workspace_mode": true,
    "r5_living_context": true,
    "nas_proxy_cache": true,
    "marvin_verification": true
  },
  "monitoring": {
    "track_metrics": true,
    "save_metrics": true,
    "alert_threshold": 0.85,
    "report_interval_minutes": 60
  }
}