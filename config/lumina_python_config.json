{
  "version": "1.0.0",
  "name": "Lumina Python Configuration",
  "description": "Python version and virtual environment configuration for the Lumina project",
  "last_updated": "2025-01-24",
  "ssot": true,
  "ssot_location": "config/lumina_python_config.json",
  
  "python": {
    "required_version": "3.11.9",
    "minimum_version": "3.11.6",
    "recommended_version": "3.11.9",
    "version_spec": ">=3.11.6,<3.12.0",
    "notes": "Python 3.11.9 is the recommended version. 3.11.6 is the minimum supported version."
  },
  
  "virtual_environment": {
    "type": "venv",
    "location": "venv",
    "activation_script_windows": "venv\\Scripts\\Activate.ps1",
    "activation_script_unix": "venv/bin/activate",
    "create_command": "python -m venv venv",
    "requirements_file": "requirements.txt"
  },
  
  "installation": {
    "windows": {
      "winget": "winget install Python.Python.3.11",
      "download_url": "https://www.python.org/downloads/release/python-3119/",
      "notes": "During installation, check 'Add Python to PATH'"
    },
    "linux": {
      "apt": "sudo apt install python3.11 python3.11-venv",
      "notes": "May require adding deadsnakes PPA for Ubuntu"
    },
    "macos": {
      "homebrew": "brew install python@3.11",
      "notes": "Python 3.11.9 available via Homebrew"
    }
  },
  
  "verification": {
    "command": "python --version",
    "expected_output": "Python 3.11.9",
    "minimum_output": "Python 3.11.6"
  },
  
  "_metadata": {
    "documentation": "docs/system/LUMINA_PYTHON_CONFIG.md",
    "related_files": [
      ".python-version",
      "pyproject.toml",
      "requirements.txt"
    ]
  }
}

