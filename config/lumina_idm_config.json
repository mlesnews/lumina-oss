{
  "version": "1.0.0",
  "name": "Lumina IDM Configuration",
  "description": "Internet Download Manager (IDM) configuration for Cursor IDE integration",
  "last_updated": "2025-01-24",
  "ssot": true,
  "ssot_location": "config/lumina_idm_config.json",
  "idm": {
    "enabled": true,
    "default_downloader": true,
    "executable_paths": [
      "D:\\Program Files (x86)\\Internet Download Manager\\idman.exe",
      "C:\\Program Files (x86)\\Internet Download Manager\\idman.exe",
      "C:\\Program Files\\Internet Download Manager\\idman.exe",
      "D:\\Program Files\\Internet Download Manager\\idman.exe"
    ],
    "default_download_path": "$env:USERPROFILE\\Downloads",
    "nas_download_path": "Z:\\downloads",
    "command_line_switches": {
      "/d": "Download URL",
      "/p": "Save path",
      "/f": "File name",
      "/n": "Start download immediately"
    }
  },
  "cursor_integration": {
    "enabled": true,
    "download_helper_script": "scripts/powershell/Invoke-IDMDownload.ps1",
    "auto_detect": true,
    "fallback_to_browser": true,
    "notes": "Cursor IDE will use IDM for downloads via the helper script"
  },
  "browser_integration": {
    "enabled": true,
    "supported_browsers": [
      "Neo",
      "Chrome",
      "Edge",
      "Firefox"
    ],
    "notes": "IDM browser integration module should be installed for browser downloads"
  },
  "llm_gguf_downloads": {
    "enabled": true,
    "default_downloader": true,
    "helper_script": "scripts/powershell/Invoke-IDMGGUFDownload.ps1",
    "python_helper": "scripts/python/download_gguf_with_idm.py",
    "default_destination": "D:\\Ollama\\models",
    "fallback_destination": "$env:USERPROFILE\\Downloads",
    "supported_sources": [
      "HuggingFace",
      "Ollama",
      "Direct URLs"
    ],
    "file_extensions": [
      ".gguf",
      ".ggml"
    ],
    "notes": "All LLM GGUF model downloads use IDM for resume capability and speed acceleration"
  },
  "usage": {
    "powershell": "& 'scripts/powershell/Invoke-IDMDownload.ps1' -Url 'https://example.com/file.zip' -Destination 'C:\\Downloads\\file.zip' -Description 'File Download'",
    "powershell_gguf": "& 'scripts/powershell/Invoke-IDMGGUFDownload.ps1' -Url 'https://huggingface.co/.../model.gguf' -ModelName "llama3.2:3b" -Destination 'D:\\Ollama\\models'",
    "python_gguf": "python scripts/python/download_gguf_with_idm.py TheBloke/Llama-2-7B-GGUF llama-2-7b.Q4_K_M.gguf llama2",
    "cursor_extension": "Use Invoke-IDMDownload.ps1 script for downloads",
    "notes": "IDM provides resume capability, speed acceleration, and download management"
  },
  "_metadata": {
    "documentation": "docs/system/LUMINA_IDM_CONFIG.md",
    "script": "scripts/powershell/Invoke-IDMDownload.ps1",
    "consumers": [
      "Cursor IDE",
      "VS Code",
      "PowerShell scripts",
      "Browser downloads"
    ]
  }
}

