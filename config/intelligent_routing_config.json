{
  "version": "1.0.0",
  "name": "Intelligent LLM Routing Configuration",
  "description": "Enhanced routing strategies for laptop LLM Docker models",
  "last_updated": "2025-12-27",

  "default_strategy": "adaptive",
  
  "routing_strategies": {
    "round_robin": {
      "description": "Cycles through available models in order",
      "use_case": "Equal distribution of requests",
      "advantages": ["Simple", "Fair distribution", "No model overload"],
      "disadvantages": ["Doesn't consider performance", "May use slower models"]
    },
    "load_balanced": {
      "description": "Routes to least loaded model",
      "use_case": "Prevent model overload",
      "advantages": ["Prevents overload", "Better resource utilization"],
      "disadvantages": ["May not choose fastest model"]
    },
    "performance_based": {
      "description": "Routes to highest performing model",
      "use_case": "Maximum speed and quality",
      "advantages": ["Best performance", "Highest success rate"],
      "disadvantages": ["May overload best models", "Ignores cost"]
    },
    "cost_aware": {
      "description": "Balances cost and performance",
      "use_case": "Cost optimization (for future cloud models)",
      "advantages": ["Cost efficient", "Good value"],
      "disadvantages": ["May sacrifice some performance"]
    },
    "latency_based": {
      "description": "Routes to lowest latency model",
      "use_case": "Urgent/low-latency requirements",
      "advantages": ["Fastest response", "Best for real-time"],
      "disadvantages": ["May not be highest quality"]
    },
    "priority_based": {
      "description": "Matches task priority with model priority",
      "use_case": "High-priority tasks get best models",
      "advantages": ["Priority-aware", "Better resource allocation"],
      "disadvantages": ["Less flexible"]
    },
    "adaptive": {
      "description": "Learns from history and adapts",
      "use_case": "Default - best overall performance",
      "advantages": ["Learns and improves", "Balanced approach", "Self-optimizing"],
      "disadvantages": ["Requires history", "More complex"]
    },
    "hybrid": {
      "description": "Combines multiple strategies based on context",
      "use_case": "Intelligent context-aware routing",
      "advantages": ["Most intelligent", "Context-aware", "Best of all worlds"],
      "disadvantages": ["Most complex", "Requires metadata"]
    }
  },

  "strategy_selection": {
    "urgent_tasks": "latency_based",
    "high_priority": "performance_based",
    "budget_constrained": "cost_aware",
    "many_models": "load_balanced",
    "default": "adaptive"
  },

  "model_priorities": {
    "laptop-llm-8b": 8,
    "kaiju-codellama-13b": 10,
    "kaiju-llama3.2-11b": 9,
    "wsl-codellama-13b": 7
  },

  "routing_rules": {
    "code_generation": {
      "preferred_models": ["codellama:13b", "qwen2.5-coder:1.5b-base"],
      "strategy": "performance_based"
    },
    "reasoning": {
      "preferred_models": ["llama3.2:11b", "llama3.1:8b"],
      "strategy": "adaptive"
    },
    "lightweight": {
      "preferred_models": ["qwen2.5-coder:1.5b-base", "gemma:2b"],
      "strategy": "round_robin"
    }
  }
}
