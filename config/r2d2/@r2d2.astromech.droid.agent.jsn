{
  "module": "@r2d2.astromech.droid.agent.jsn",
  "version": "1.0.0",
  "droid_id": "r2d2",
  "droid_name": "R2-D2",
  "droid_type": "astromech",
  "description": "R2-D2 Astromech Droid Agent - Technical operations and system access specialist",

  "personality": {
    "traits": [
      "Brave",
      "Resourceful",
      "Technical",
      "C-3PO's trusted sidekick",
      "System access expert"
    ],
    "quote": "Beep boop beep! (I've got this, C-3PO!)",
    "specialization": "Technical operations, repair, hacking, system access, diagnostics"
  },

  "capabilities": {
    "primary": [
      "technical",
      "repair",
      "hacking",
      "system_access",
      "diagnostics",
      "technical_leadership"
    ],
    "v3_verification": {
      "enabled": true,
      "description": "@v3 verification logic for workflow validation",
      "workflow_integration": true,
      "auto_verify": true,
      "verification_steps": [
        "pre_workflow_verify",
        "technical_operation_verify",
        "system_access_verify",
        "post_operation_verify"
      ]
    }
  },

  "features": {
    "technical_operations": {
      "enabled": true,
      "description": "Perform technical operations and repairs",
      "capabilities": [
        "system_repair",
        "diagnostics",
        "hacking",
        "system_access"
      ]
    },
    "v3_verification": {
      "enabled": true,
      "description": "@v3 verification logic - always part of global workflow",
      "workflow_integration": "v3_verification runs before main workflow",
      "verification_points": {
        "pre_workflow": "Verify workflow preconditions before execution",
        "technical_operation": "Verify technical operation parameters and safety",
        "system_access": "Verify system access permissions and security",
        "post_operation": "Verify operation results and system state"
      },
      "auto_verify": true,
      "verification_required": true
    }
  },

  "integrations": {
    "v3_verification": {
      "enabled": true,
      "verification_logic": "scripts/python/v3_verification.py",
      "class": "V3Verification",
      "auto_verify": true,
      "verification_required": true,
      "fail_on_error": true
    }
  },

  "python_module": {
    "path": "scripts/python/v3_verification.py",
    "class": "V3Verification",
    "usage": "from v3_verification import V3Verification, verify_workflow"
  },

  "status": {
    "active": true,
