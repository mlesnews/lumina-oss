{
  "version": "1.0.0",
  "name": "Local AI Auto-Start Configuration",
  "description": "Auto-start local AI services with smart resource awareness and dynamic scaling",
  "last_updated": "2026-01-06",
  "auto_start": {
    "enabled": true,
    "start_on_boot": true,
    "check_interval": 10
  },
  "resource_awareness": {
    "enabled": true,
    "cpu_threshold_low": 0.3,
    "cpu_threshold_high": 0.7,
    "cpu_threshold_critical": 0.8,
    "memory_threshold": 0.8,
    "check_interval": 10
  },
  "dynamic_scaling": {
    "enabled": true,
    "min_scale": 1,
    "max_scale": 3,
    "scale_up_threshold": 0.7,
    "scale_down_threshold": 0.3,
    "critical_threshold": 0.8
  },
  "services": {
    "ULTRON": {
      "enabled": true,
      "priority": 1,
      "endpoint": "http://localhost:11434",
      "health_check_url": "http://localhost:11434/api/tags",
      "min_instances": 1,
      "max_instances": 2,
      "always_running": true,
      "start_command": ["docker", "start", "ollama"],
      "stop_command": ["docker", "stop", "ollama"]
    },
    "KAIJU": {
      "enabled": true,
      "priority": 2,
      "endpoint": "http://<NAS_PRIMARY_IP>:11434",
      "health_check_url": "http://<NAS_PRIMARY_IP>:11434/api/tags",
      "min_instances": 0,
      "max_instances": 1,
      "always_running": false,
      "start_command": ["ssh", "kaiju", "docker start ollama"],
      "stop_command": ["ssh", "kaiju", "docker stop ollama"],
      "scale_down_on_high_cpu": true,
      "cpu_threshold_scale_down": 0.7
    }
  },
  "monitoring": {
    "enabled": true,
    "log_metrics": true,
    "metrics_file": "data/ai_service_metrics.json",
    "alert_on_critical": true,
    "alert_threshold": 0.8
  }
}
