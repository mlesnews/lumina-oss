  "workflows": {
    "email_send": {
      "workflow_id": "email_send",
      "name": "Email Send",
      "webhook_path": "/email/send",
      "trigger_type": "webhook",
      "nodes": [
        {
          "type": "webhook",
          "name": "Receive Email Request"
        },
        {
          "type": "function",
          "name": "Validate Email"
        },
        {
          "type": "email",
          "name": "Send Email (SMTP/Gmail/Outlook)"
        },
        {
          "type": "function",
          "name": "Track Status"
        }
      ],
      "enabled": true,
      "metadata": {}
    },
    "email_receive": {
      "workflow_id": "email_receive",
      "name": "Email Receive",
      "webhook_path": "/email/receive",
      "trigger_type": "schedule",
      "nodes": [
        {
          "type": "schedule",
          "name": "Check Every 5 Minutes"
        },
        {
          "type": "imap",
          "name": "Check Email (IMAP)"
        },
        {
          "type": "function",
          "name": "Process New Emails"
        },
        {
          "type": "webhook",
          "name": "@syphon Email Extraction",
          "webhook_path": "/webhook/syphon/email",
          "description": "Extract actionable intelligence from email"
        },
        {
          "type": "webhook",
          "name": "Notify System"
        }
      ],
      "enabled": true,
      "metadata": {
        "syphon_enabled": true,
        "syphon_endpoint": "/webhook/syphon/email"
      }
    },
    "email_syphon": {
      "workflow_id": "email_syphon",
      "name": "Email @SYPHON Extraction",
      "webhook_path": "/webhook/syphon/email",
      "trigger_type": "webhook",
      "nodes": [
        {
          "type": "webhook",
          "name": "Receive Email for SYPHON",
          "settings": {
            "path": "syphon/email",
            "httpMethod": "POST"
          }
        },
        {
          "type": "http",
          "name": "Call SYPHON System",
          "settings": {
            "url": "http://localhost:8000/api/syphon/email",
            "method": "POST"
          }
        },
        {
          "type": "function",
          "name": "Extract Actionable Items",
          "description": "Extract actionable items, tasks, decisions, and intelligence"
        },
        {
          "type": "webhook",
          "name": "Save to Actionable Intelligence",
          "settings": {
            "url": "http://localhost:8000/api/intelligence/actionable",
            "method": "POST"
          }
        }
      ],
      "enabled": true,
      "metadata": {
        "syphon_system": true,
        "extracts": ["actionable_items", "tasks", "decisions", "intelligence"]
      }
    },
