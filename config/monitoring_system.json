{
  "metrics": {
    "system": {
      "cpu_usage": {
        "threshold": 80,
        "alert": "email"
      },
      "memory_usage": {
        "threshold": 85,
        "alert": "email"
      },
      "disk_usage": {
        "threshold": 90,
        "alert": "email"
      }
    },
    "application": {
      "error_rate": {
        "threshold": 5,
        "alert": "email"
      },
      "response_time": {
        "threshold": 5000,
        "alert": "slack"
      },
      "workflow_failures": {
        "threshold": 3,
        "alert": "email"
      }
    },
    "business": {
      "active_workflows": {
        "threshold": 100,
        "alert": "dashboard"
      },
      "api_call_volume": {
        "threshold": 1000,
        "alert": "dashboard"
      }
    }
  },
  "alert_channels": {
    "email": {
      "recipients": [
        "${ADMIN_EMAIL}"
      ],
      "template": "alert_email.txt"
    },
    "slack": {
      "webhook_url": "${SLACK_WEBHOOK}",
      "channel": "#alerts"
    },
    "dashboard": {
      "endpoint": "${DASHBOARD_API_URL}",
      "api_key": "${DASHBOARD_API_KEY}"
    }
  },
  "monitoring_schedule": {
    "system_metrics": "*/5 * * * *",
    "application_metrics": "*/1 * * * *",
    "business_metrics": "0 */1 * * *",
    "health_checks": "*/10 * * * *"
  }
}