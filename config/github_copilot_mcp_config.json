{
  "version": "2.0",
  "name": "GitHub Copilot MCP Configuration",
  "description": "GitHub Copilot coding assistant configuration - Aligned with Docker MCP config for all IDEs",
  "last_updated": "2024-12-19",
  "github_copilot": {
    "type": "coding_assistant",
    "name": "GitHub Copilot",
    "extension_id": "github.copilot",
    "priority": "high",
    "status": "active",
    "requires_approval": true,
    "config_file": "config/multi_ide_optimal_settings.json",
    "endpoint": "http://localhost:8080/assistants/copilot",
    "capabilities": [
      "autocomplete",
      "code_generation",
      "broad_language_support"
    ],
    "integrations": [
      "github",
      "openai"
    ],
    "models": {
      "primary": "gpt-4",
      "fallback": "gpt-3.5-turbo"
    },
    "mcp": {
      "enabled": true,
      "requires_approval": true,
      "hub_endpoint": "http://localhost:8080",
      "hub_health_check": "http://localhost:8080/health",
      "assistant_endpoint": "http://localhost:8080/assistants/copilot",
      "unified_management": false,
      "air_gap_mode": "blocked"
    },
    "ide_support": {
      "cursor": {
        "enabled": true,
        "requires_approval": true,
        "priority": 4,
        "adapter_port": 8083
      },
      "vscode": {
        "enabled": true,
        "requires_approval": true,
        "priority": 4,
        "adapter_port": 8082
      },
      "abacus": {
        "enabled": true,
        "requires_approval": true,
        "priority": 4,
        "adapter_port": 8084
      }
    },
    "security": {
      "cloud_based": true,
      "air_gap_mode": "blocked",
      "requires_explicit_approval": true
    }
  }
}