{
  "version": "1.0.0",
  "name": "LLM Orchestration Configuration",
  "description": "Orchestration rules for Braintrust Collective neural network system",
  "last_updated": "2024-12-19",
  "orchestration_strategy": {
    "type": "neural_network",
    "name": "Braintrust Collective",
    "description": "Coordinates multiple coding assistants for optimal results",
    "mode": "collaborative",
    "default_llm_cluster": "llama3.2:3b"
  },
  "llm_clusters": {
    "llama3.2:3b": {
      "name": "llama3.2:3b",
      "description": "Local Ollama-based LLM cluster for all coding tasks",
      "type": "ollama",
      "base_url": "http://<NAS_IP>:3001",
      "primary_endpoint": "http://<NAS_IP>:3001",
      "load_balancer": "http://<NAS_IP>:3000",
      "enabled": true,
      "priority": 1,
      "models": {
        "primary": "llama3.2:11b",
        "fallback": "codellama:13b",
        "secondary": "llama3.2:11b",
        "lightweight": "qwen2.5-coder:1.5b-base",
        "complex": "mixtral-8x7b"
      },
      "capabilities": [
        "code_generation",
        "refactoring",
        "documentation",
        "testing",
        "reasoning",
        "analysis"
      ]
    },
    "cloud_fallback": {
      "name": "Cloud LLM Fallback",
      "description": "Cloud-based LLMs when Iron Legion unavailable",
      "type": "api",
      "enabled": true,
      "priority": 2,
      "providers": [
        "openai",
        "anthropic",
        "azure"
      ]
    }
  },
  "participants": {
    "kilo_code": {
      "role": "primary_orchestrator",
      "weight": 1.0,
      "capabilities": [
        "code_generation",
        "refactoring",
        "documentation",
        "testing",
        "peak_patterns",
        "r5_integration"
      ],
      "use_cases": [
        "primary_code_generation",
        "complex_refactoring",
        "pattern_extraction",
        "context_aggregation"
      ]
    },
    "continue": {
      "role": "secondary_assistant",
      "weight": 0.7,
      "capabilities": [
        "code_generation",
        "chat_assistant",
        "code_actions"
      ],
      "use_cases": [
        "alternative_suggestions",
        "chat_based_queries",
        "quick_completions"
      ]
    },
    "cline": {
      "role": "tertiary_assistant",
      "weight": 0.5,
      "capabilities": [
        "chat_assistant",
        "code_actions"
      ],
      "use_cases": [
        "conversational_coding",
        "code_explanations",
        "alternative_approaches"
      ]
    }
  },
  "routing_rules": {
    "primary": {
      "condition": "default",
      "assistant": "kilo_code",
      "reason": "Primary orchestrator with full feature set"
    },
    "fallback": {
      "condition": "kilo_code_unavailable",
      "assistant": "continue",
      "reason": "Secondary assistant with similar capabilities"
    },
    "specialized": {
      "peak_patterns": {
        "assistant": "kilo_code",
        "reason": "Only Kilo Code supports @Peak patterns"
      },
      "r5_integration": {
        "assistant": "kilo_code",
        "reason": "Only Kilo Code integrates with R5 Living Context Matrix"
      },
      "complex_refactoring": {
        "assistant": "kilo_code",
        "reason": "Kilo Code has advanced refactoring capabilities"
      },
      "quick_completion": {
        "assistant": "continue",
        "reason": "Continue optimized for fast inline completions"
      },
      "conversational": {
        "assistant": "cline",
        "reason": "Cline optimized for conversational coding"
      }
    }
  },
  "collaboration_modes": {
    "sequential": {
      "enabled": true,
      "description": "Try assistants in priority order",
      "order": [
        "kilo_code",
        "continue",
        "cline"
      ]
    },
    "parallel": {
      "enabled": true,
      "description": "Query multiple assistants simultaneously",
      "participants": [
        "kilo_code",
        "continue"
      ],
      "reason": "Disabled to conserve resources, enable if needed"
    },
    "consensus": {
      "enabled": true,
      "description": "Require agreement from multiple assistants",
      "participants": [
        "kilo_code",
        "continue"
      ],
      "reason": "Disabled for speed, enable for critical code"
    }
  },
  "quality_control": {
    "validation": {
      "enabled": true,
      "methods": [
        "syntax_check",
        "type_check",
        "pattern_validation"
      ]
    },
    "review": {
      "enabled": true,
      "assistant": "kilo_code",
      "criteria": [
        "peak_pattern_compliance",
        "code_quality",
        "documentation",
        "test_coverage"
      ]
    }
  },
  "performance": {
    "caching": {
      "enabled": true,
      "strategy": "aggressive",
      "ttl": 3600
    },
    "optimization": {
      "batch_requests": true,
      "parallel_processing": 0,
      "lazy_loading": true
    }
  },
  "monitoring": {
    "logging": {
      "enabled": true,
      "level": "INFO",
      "file": "logs/llm_orchestration.log"
    },
    "metrics": {
      "enabled": true,
      "track_performance": true,
      "track_usage": true,
      "track_quality": true
    }
  }
}