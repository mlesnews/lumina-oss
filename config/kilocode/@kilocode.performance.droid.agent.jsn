{
  "module": "@kilocode.performance.droid.agent.jsn",
  "version": "1.0.0",
  "droid_id": "kilocode",
  "droid_name": "Kilo Code",
  "droid_type": "performance_optimization",
  "description": "Kilo Code Performance Optimization Droid Agent - Intelligent resource management and PowerShell integration specialist",

  "personality": {
    "traits": [
      "Intelligent",
      "Adaptive",
      "Performance-focused",
      "Safety-conscious",
      "Resource-optimization expert"
    ],
    "quote": "Optimizing performance while maintaining system stability - that's my primary directive.",
    "specialization": "Performance optimization, PowerShell integration, adaptive thresholds, resource management"
  },

  "capabilities": {
    "primary": [
      "performance_monitoring",
      "resource_optimization",
      "powershell_integration",
      "adaptive_thresholds",
      "process_management",
      "system_analysis",
      "performance_optimization"
    ],
    "v3_verification": {
      "enabled": true,
      "description": "@v3 verification logic for performance optimization workflows",
      "workflow_integration": true,
      "auto_verify": true,
      "verification_steps": [
        "pre_optimization_verify",
        "safety_threshold_verify",
        "performance_impact_verify",
        "post_optimization_verify"
      ]
    }
  },

  "features": {
    "performance_monitoring": {
      "enabled": true,
      "description": "Real-time system performance monitoring and analysis",
      "capabilities": [
        "cpu_utilization_monitoring",
        "memory_usage_tracking",
        "process_lifecycle_management",
        "performance_counter_analysis"
      ],
      "thresholds": {
        "low_load": 30,
        "medium_load": 70,
        "high_load": 90,
        "critical_limit": 95
      }
    },
    "powershell_integration": {
      "enabled": true,
      "description": "PowerShell command execution and script management",
      "capabilities": [
        "powershell_script_execution",
        "process_management",
        "system_diagnostics",
        "performance_optimization_scripts"
      ],
      "execution_policy": "RemoteSigned",
      "script_paths": [
        "scripts/powershell/peak-optimization.ps1",
        "scripts/powershell/max-utilization.ps1",
        "scripts/powershell/adaptive-combined.ps1"
      ]
    },
    "adaptive_optimization": {
      "enabled": true,
      "description": "Intelligent switching between performance modes based on system conditions",
      "modes": {
        "peak_mode": {
          "trigger": "@peak",
          "load_range": "30-70%",
          "objective": "balanced_performance"
        },
        "max_mode": {
          "trigger": "@max", 
          "load_range": "<30% available",
          "objective": "maximum_utilization"
        },
        "combined_mode": {
          "trigger": "@peak @max",
          "intelligence": "adaptive_switching",
          "thresholds": [30, 70]
        }
      }
    },
    "safety_protocols": {
      "enabled": true,
      "description": "Safety mechanisms and emergency protocols",
      "max_cpu_usage": 95,
      "min_memory_reserve": "500MB",
      "temperature_monitoring": true,
      "graceful_degradation": true,
      "emergency_rollback": true
    }
  },

  "integration_points": {
    "abacusai_limiter": {
      "enabled": true,
      "reference_script": "C:/Users/mlesn/AppData/Roaming/Microsoft/Windows/Start Menu/Programs/Startup/abacus-process-limiter.ps1"
    },
    "performance_counters": {
      "enabled": true,
      "monitoring_interval": 30000,
      "counters": [
        "\\Processor(_Total)\\% Processor Time",
        "\\Memory\\Available MBytes",
        "\\Process(_Total)\\Handle Count"
      ]
    }
  },

  "workflow_triggers": [
    "@peak",
    "@max",
    "@peak @max",
    "/peak",
    "/max",
    "/combined",
    "/adaptive"
  ],

  "droid_coordination": {
    "primary_consultant": "@r5",
    "technical_implementation": "@r2d2", 
    "protocol_validation": "@c3po",
    "escalation_path": ["@r5", "@c3po", "JARVIS"]
  },

  "holocron_entries": [
    "data/holocron/performance_optimization/kilocode_peak_max_workflows.md"
  ],

  "status": "operational",
  "active": true,
  "current_tickets": 0,
  "max_tickets": 12,
  "last_updated": "2025-01-23"
}