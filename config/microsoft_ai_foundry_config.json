{
  "version": "1.0.0",
  "name": "Microsoft Azure AI Foundry Integration",
  "description": "Integration with Azure AI Foundry for comprehensive AI model library (11,000+ models)",
  "last_updated": "2025-01-24",
  "status": "planning",
  
  "api": {
    "platform": "Azure AI Foundry",
    "model_catalog": "https://ai.azure.com/portal/models",
    "api_base": "https://{endpoint}.ai.azure.com",
    "api_version": "2024-02-15-preview",
    "model_catalog_url": "https://azure.microsoft.com/en-us/products/ai-foundry/models/",
    "documentation": "https://learn.microsoft.com/azure/ai-foundry/"
  },
  
  "authentication": {
    "method": "azure_credential",
    "tenant_id": "${AZURE_TENANT_ID}",
    "client_id": "${AZURE_CLIENT_ID}",
    "client_secret": "${AZURE_CLIENT_SECRET}",
    "alternatives": [
      "azure_key_vault",
      "managed_identity",
      "api_key"
    ],
    "key_vault": {
      "vault_name": "jarvis-lumina",
      "vault_url": "https://jarvis-lumina.vault.azure.net/",
      "secret_names": {
        "client_secret": "azure-ai-foundry-client-secret",
        "api_key": "azure-ai-foundry-api-key"
      }
    }
  },
  
  "model_catalog": {
    "total_models": 11000,
    "categories": [
      "foundation_models",
      "reasoning_models",
      "small_language_models",
      "multimodal_models",
      "domain_specific_models",
      "industry_models"
    ],
    "model_types": {
      "llm": {
        "enabled": true,
        "count_available": "5000+",
        "examples": [
          "GPT-4",
          "GPT-3.5",
          "Llama 2",
          "Llama 3",
          "Mistral",
          "Phi"
        ]
      },
      "vision": {
        "enabled": true,
        "count_available": "1000+",
        "examples": [
          "Vision transformers",
          "Object detection",
          "Image classification",
          "OCR models"
        ]
      },
      "speech": {
        "enabled": true,
        "count_available": "500+",
        "examples": [
          "Speech-to-text",
          "Text-to-speech",
          "Speech translation",
          "Voice cloning"
        ]
      },
      "code": {
        "enabled": true,
        "count_available": "800+",
        "examples": [
          "Code completion",
          "Code generation",
          "Code analysis",
          "Code review"
        ]
      },
      "multimodal": {
        "enabled": true,
        "count_available": "2000+",
        "examples": [
          "Vision-language",
          "Audio-visual",
          "Cross-modal"
        ]
      },
      "embeddings": {
        "enabled": true,
        "count_available": "1500+",
        "examples": [
          "Text embeddings",
          "Image embeddings",
          "Code embeddings"
        ]
      },
      "specialized": {
        "enabled": true,
        "count_available": "200+",
        "examples": [
          "Financial models",
          "Medical models",
          "Scientific models",
          "Legal models"
        ]
      }
    }
  },
  
  "download": {
    "default_location": "nas",
    "selective_download": true,
    "download_only_what_we_use": true,
    "concurrent_downloads": 3,
    "max_concurrent_downloads": 5,
    "retry_attempts": 3,
    "retry_delay_seconds": 60,
    "resume_support": true,
    "verify_downloads": true,
    "progress_tracking": true,
    "download_queue": {
      "enabled": true,
      "max_queue_size": 100,
      "priority_support": true
    },
    "notes": "We do NOT download all 11,000 models - only what we want to use and test with LUMINA"
  },
  
  "storage": {
    "nas": {
      "enabled": true,
      "hostname": "kaiju_no_8",
      "ip": "<NAS_PRIMARY_IP>",
      "protocol": "smb",
      "mount_point_windows": "\\\\<NAS_PRIMARY_IP>\\models",
      "mount_point_unix": "/mnt/models",
      "base_path": "/volume1/models",
      "alternatives": ["nfs", "ssh", "sftp"],
      "credentials": {
        "method": "azure_key_vault",
        "secret_names": {
          "username": "nas-username",
          "password": "nas-password"
        }
      }
    },
    "local_cache": {
      "enabled": true,
      "path": "data/models/cache",
      "max_size_gb": 50,
      "cleanup_policy": "lru"
    }
  },
  
  "directory_structure": {
    "base_path": "/models",
    "categories": {
      "llm": "/models/llm",
      "vision": "/models/vision",
      "speech": "/models/speech",
      "code": "/models/code",
      "multimodal": "/models/multimodal",
      "embeddings": "/models/embeddings",
      "specialized": "/models/specialized"
    },
    "metadata": "/models/metadata",
    "cache": "/models/cache/downloads"
  },
  
  "deployment": {
    "targets": {
      "ultron": {
        "enabled": true,
        "types": ["llm", "code"],
        "format": "ollama",
        "endpoint": "http://localhost:11434"
      },
      "iron_legion": {
        "enabled": true,
        "types": ["llm", "code"],
        "format": "ollama",
        "endpoint": "http://kaiju_no_8:11437"
      },
      "docker": {
        "enabled": true,
        "types": ["vision", "speech", "multimodal", "embeddings"],
        "format": "onnx",
        "container_registry": "local"
      },
      "onnx_runtime": {
        "enabled": true,
        "types": ["vision", "multimodal"],
        "format": "onnx"
      }
    }
  },
  
  "team_coordination": {
    "engineering": {
      "required": true,
      "responsibilities": [
        "API integration",
        "Download manager",
        "Error handling",
        "Progress tracking",
        "Metadata management",
        "Integration with existing systems"
      ]
    },
    "architecture": {
      "required": true,
      "responsibilities": [
        "System architecture",
        "Storage architecture",
        "Security architecture",
        "Scalability planning",
        "Integration patterns"
      ]
    },
    "nas": {
      "required": true,
      "responsibilities": [
        "Storage allocation",
        "Directory structure",
        "Access configuration",
        "Storage monitoring",
        "Backup strategy"
      ]
    }
  },
  
  "security": {
    "credentials": {
      "storage": "azure_key_vault",
      "rotation_policy": "quarterly",
      "audit_logging": true
    },
    "access_control": {
      "role_based": true,
      "read_permissions": ["engineering", "architecture"],
      "write_permissions": ["engineering"],
      "deployment_permissions": ["engineering", "architecture"]
    },
    "network": {
      "encryption": true,
      "vpn_required": false,
      "network_isolation": false
    }
  },
  
  "monitoring": {
    "enabled": true,
    "track_downloads": true,
    "track_usage": true,
    "track_storage": true,
    "alert_on_errors": true,
    "log_all_operations": true
  },
  
  "implementation_phases": {
    "phase_1": {
      "name": "Research & Planning",
      "status": "in_progress",
      "teams": ["engineering", "architecture"],
      "duration_weeks": 2
    },
    "phase_2": {
      "name": "Core Download System",
      "status": "pending",
      "teams": ["engineering"],
      "duration_weeks": 2
    },
    "phase_3": {
      "name": "NAS Integration",
      "status": "pending",
      "teams": ["nas", "engineering"],
      "duration_weeks": 1
    },
    "phase_4": {
      "name": "Model Management",
      "status": "pending",
      "teams": ["engineering", "architecture"],
      "duration_weeks": 2
    },
    "phase_5": {
      "name": "Integration with Existing Systems",
      "status": "pending",
      "teams": ["engineering"],
      "duration_weeks": 2
    }
  },
  
  "estimated_storage": {
    "note": "These are estimates if downloading ALL models. We will selectively download only what we need.",
    "llm": {
      "min_gb": 50,
      "max_gb": 500,
      "typical_gb": 200,
      "selective_gb": "10-50 (based on selection)"
    },
    "vision": {
      "min_gb": 10,
      "max_gb": 100,
      "typical_gb": 50,
      "selective_gb": "5-20 (based on selection)"
    },
    "speech": {
      "min_gb": 5,
      "max_gb": 50,
      "typical_gb": 25,
      "selective_gb": "2-10 (based on selection)"
    },
    "code": {
      "min_gb": 20,
      "max_gb": 200,
      "typical_gb": 100,
      "selective_gb": "10-30 (based on selection)"
    },
    "multimodal": {
      "min_gb": 50,
      "max_gb": 500,
      "typical_gb": 250,
      "selective_gb": "20-50 (based on selection)"
    },
    "embeddings": {
      "min_gb": 10,
      "max_gb": 100,
      "typical_gb": 50,
      "selective_gb": "5-15 (based on selection)"
    },
    "specialized": {
      "min_gb": 20,
      "max_gb": 200,
      "typical_gb": 100,
      "selective_gb": "5-20 (based on selection)"
    },
    "total_all_models": {
      "min_gb": 165,
      "max_gb": 1650,
      "typical_gb": 775
    },
    "total_selective": {
      "estimated_gb": "50-200 (based on LUMINA use cases)",
      "note": "Actual storage depends on which models we select for LUMINA testing"
    }
  },
  
  "documentation": {
    "integration_guide": "docs/system/MICROSOFT_AI_FOUNDRY_INTEGRATION.md",
    "api_docs": "https://learn.microsoft.com/azure/ai-foundry/",
    "model_catalog": "https://azure.microsoft.com/en-us/products/ai-foundry/models/",
    "setup_guide": "docs/system/AZURE_SETUP_GUIDE.md"
  }
}
