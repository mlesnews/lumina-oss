{
  "selective_remote_sync": {
    "name": "Selective Remote Sync Configuration",
    "version": "1.0.0",
    "description": "Selective sync of directories/files for remote work (with/without VPN) while maintaining full storage on LAN/NAS",
    "created_at": "2026-01-06",
    "tags": ["@proton", "@dropbox", "@onedrive", "#remote-work", "#vpn", "#selective-sync"],
    "status": "active",
    "strategy": {
      "full_storage_location": "N:\\",
      "full_storage_description": "Complete Dropbox and cloud storage on NAS (LAN only)",
      "selective_sync_location": "cloud_storage_aggregated",
      "selective_sync_description": "Selected directories/files for remote access",
      "sync_mode": "selective",
      "vpn_required": false,
      "vpn_preferred": true
    },
    "local_storage": {
      "nas_drive": "N:",
      "nas_path": "\\\\<NAS_PRIMARY_IP>\\backups\\MATT_Backups",
      "full_dropbox_path": "N:\\Dropbox",
      "full_cloud_storage_path": "N:\\cloud_storage_aggregated",
      "description": "All cloud storage maintained locally on NAS for LAN access"
    },
    "remote_sync_directories": {
      "active_projects": {
        "enabled": true,
        "local_path": "N:\\my_projects",
        "remote_sync_paths": {
          "dropbox": "N:\\cloud_storage_aggregated\\dropbox\\my_projects",
          "onedrive": "N:\\cloud_storage_aggregated\\onedrive\\my_projects",
          "protondrive": "N:\\cloud_storage_aggregated\\protondrive\\my_projects"
        },
        "description": "Active development projects - sync for remote work",
        "priority": 1,
        "sync_frequency": "real-time",
        "vpn_optional": true
      },
      "documents": {
        "enabled": true,
        "local_path": "N:\\Documents",
        "remote_sync_paths": {
          "dropbox": "N:\\cloud_storage_aggregated\\dropbox\\Documents",
          "onedrive": "N:\\cloud_storage_aggregated\\onedrive\\Documents",
          "protondrive": "N:\\cloud_storage_aggregated\\protondrive\\Documents"
        },
        "description": "Important documents - sync for remote access",
        "priority": 2,
        "sync_frequency": "real-time",
        "vpn_optional": true
      },
      "config_files": {
        "enabled": true,
        "local_path": "N:\\my_projects\\.lumina\\config",
        "remote_sync_paths": {
          "dropbox": "N:\\cloud_storage_aggregated\\dropbox\\config",
          "protondrive": "N:\\cloud_storage_aggregated\\protondrive\\config"
        },
        "description": "Configuration files - encrypted sync via ProtonDrive",
        "priority": 1,
        "sync_frequency": "real-time",
        "vpn_optional": false,
        "encryption_required": true,
        "preferred_provider": "protondrive"
      },
      "scripts": {
        "enabled": true,
        "local_path": "N:\\my_projects\\.lumina\\scripts",
        "remote_sync_paths": {
          "dropbox": "N:\\cloud_storage_aggregated\\dropbox\\scripts",
          "protondrive": "N:\\cloud_storage_aggregated\\protondrive\\scripts"
        },
        "description": "Scripts and automation - sync for remote execution",
        "priority": 2,
        "sync_frequency": "on-demand",
        "vpn_optional": true
      }
    },
    "excluded_from_remote_sync": {
      "large_data": {
        "patterns": [
          "**/node_modules/**",
          "**/.git/objects/**",
          "**/venv/**",
          "**/.venv/**",
          "**/__pycache__/**",
          "**/*.pyc",
          "**/data/large/**",
          "**/data/cache/**",
          "**/backups/**"
        ],
        "description": "Large files and caches - LAN only, no remote sync"
      },
      "sensitive_local_only": {
        "patterns": [
          "**/secrets/**",
          "**/credentials/**",
          "**/.env.local",
          "**/local_backup/**"
        ],
        "description": "Sensitive files - LAN only, never synced remotely"
      }
    },
    "proton_family_integration": {
      "subscription": "proton_family",
      "products": {
        "protondrive": {
          "enabled": true,
          "priority": 1,
          "description": "Primary encrypted cloud storage for sensitive files",
          "encryption": "end-to-end",
          "sync_path": "N:\\cloud_storage_aggregated\\protondrive",
          "dsm_cloud_sync": true,
          "webdav_support": true,
          "api_integration": true
        },
        "protonmail": {
          "enabled": true,
          "description": "Email service integration",
          "bridge_required": true,
          "nas_integration": "config/outlook/hybrid_email_config.json"
        },
        "protonvpn": {
          "enabled": true,
          "description": "VPN service for secure remote access",
          "vpn_required_for": [
            "sensitive_config_files",
            "encrypted_data"
          ],
          "auto_connect": true,
          "preferred_server": "fastest"
        },
        "protoncalendar": {
          "enabled": true,
          "description": "Calendar integration",
          "sync_enabled": true
        },
        "protonpass": {
          "enabled": true,
          "description": "Password manager integration",
          "vault_sync": true
        }
      },
      "credentials": {
        "storage": "azure_key_vault",
        "secrets": [
          "proton-account-username",
          "proton-account-password",
          "proton-api-key",
          "protonvpn-credentials"
        ]
      }
    },
    "sync_strategy": {
      "lan_access": {
        "mode": "full",
        "description": "Full access to all data on NAS via N: drive",
        "location": "N:\\",
        "performance": "maximum",
        "no_bandwidth_limit": true
      },
      "remote_with_vpn": {
        "mode": "selective",
        "description": "Selective sync via ProtonVPN for secure access",
        "vpn_provider": "protonvpn",
        "sync_providers": ["protondrive", "dropbox", "onedrive"],
        "encryption": "required",
        "preferred_provider": "protondrive"
      },
      "remote_without_vpn": {
        "mode": "selective",
        "description": "Selective sync without VPN (less sensitive files only)",
        "sync_providers": ["dropbox", "onedrive"],
        "excluded_providers": ["protondrive"],
        "encryption": "recommended",
        "sensitive_files_excluded": true
      }
    },
    "dsm_cloud_sync_config": {
      "selective_sync_enabled": true,
      "sync_rules": {
        "include_patterns": [
          "my_projects/**",
          "Documents/**",
          "config/**",
          "scripts/**"
        ],
        "exclude_patterns": [
          "**/node_modules/**",
          "**/.git/objects/**",
          "**/venv/**",
          "**/__pycache__/**",
          "**/data/large/**",
          "**/secrets/**"
        ]
      },
      "providers": {
        "dropbox": {
          "selective_sync": true,
          "sync_path": "N:\\cloud_storage_aggregated\\dropbox",
          "priority": 2
        },
        "onedrive": {
          "selective_sync": true,
          "sync_path": "N:\\cloud_storage_aggregated\\onedrive",
          "priority": 3
        },
        "protondrive": {
          "selective_sync": true,
          "sync_path": "N:\\cloud_storage_aggregated\\protondrive",
          "priority": 1,
          "encryption": true
        }
      }
    },
    "migration_plan": {
      "phase_1": {
        "name": "Full Local Storage Migration",
        "description": "Migrate all Dropbox data to NAS (N: drive) for LAN access",
        "source": "C:\\Users\\mlesn\\Dropbox",
        "destination": "N:\\Dropbox",
        "status": "pending",
        "estimated_size": "4.5TB",
        "estimated_time": "24-48 hours"
      },
      "phase_2": {
        "name": "Selective Remote Sync Setup",
        "description": "Configure selective sync for remote work directories",
        "directories": [
          "my_projects",
          "Documents",
          "config",
          "scripts"
        ],
        "status": "pending"
      },
      "phase_3": {
        "name": "Proton Family Integration",
        "description": "Configure Proton family products for secure remote access",
        "products": [
          "ProtonDrive",
          "ProtonVPN",
          "ProtonMail",
          "ProtonCalendar",
          "ProtonPass"
        ],
        "status": "pending"
      }
    },
    "documentation": {
      "migration_guide": "docs/system/DROPBOX_TO_NAS_MIGRATION.md",
      "selective_sync_guide": "docs/system/SELECTIVE_REMOTE_SYNC_SETUP.md",
      "proton_integration_guide": "docs/system/PROTON_FAMILY_INTEGRATION.md"
    },
    "updated_at": "2026-01-06T02:00:00.000000"
  }
}
