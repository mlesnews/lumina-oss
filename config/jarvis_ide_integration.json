{
  "version": "1.0.0",
  "name": "JARVIS IDE Integration",
  "description": "JARVIS Master Agent integration with all IDEs and coding assistants - @Peak required",
  "last_updated": "2024-12-19",

  "jarvis": {
    "master_agent": true,
    "enabled": true,
    "required": true,
    "endpoint": "data/jarvis_intelligence",
    "ingestion_path": "data/jarvis_ingestion",
    "content_index": "config/lumina_jarvis_content_index.json"
  },

  "ide_integrations": {
    "cursor": {
      "enabled": true,
      "required": true,
      "adapter_port": 8083,
      "integration_points": [
        "code_generation",
        "pattern_extraction",
        "spark_transmission",
        "workflow_verification",
        "knowledge_aggregation"
      ],
      "peak_required": true
    },
    "vscode": {
      "enabled": true,
      "required": true,
      "adapter_port": 8082,
      "integration_points": [
        "code_generation",
        "pattern_extraction",
        "workflow_verification",
        "knowledge_aggregation"
      ],
      "peak_required": true
    },
    "abacus": {
      "enabled": true,
      "required": true,
      "adapter_port": 8084,
      "integration_points": [
        "code_generation",
        "pattern_extraction",
        "workflow_verification",
        "knowledge_aggregation"
      ],
      "peak_required": true
    }
  },

  "assistant_integrations": {
    "kilo_code": {
      "enabled": true,
      "required": true,
      "endpoint": "http://localhost:8080/assistants/kilo_code",
      "integration_points": [
        "code_generation",
        "pattern_extraction",
        "peak_patterns",
        "watcher_uatu_sparks",
        "r5_context"
      ],
      "peak_required": true,
      "jarvis_priority": "high"
    },
    "continue": {
      "enabled": true,
      "required": false,
      "endpoint": "http://localhost:8080/assistants/continue",
      "integration_points": [
        "code_generation",
        "workflow_verification"
      ],
      "peak_required": false
    },
    "cline": {
      "enabled": true,
      "required": false,
      "endpoint": "http://localhost:8080/assistants/cline",
      "integration_points": [
        "code_generation",
        "workflow_verification"
      ],
      "peak_required": false
    }
  },

  "features": {
    "orchestration": true,
    "workflow_management": true,
    "knowledge_aggregation": true,
    "escalation_handling": true,
    "peak_pattern_integration": true,
    "watcher_uatu_integration": true,
    "r5_integration": true,
    "helpdesk_integration": true
  },

  "peak_enforcement": {
    "required": true,
    "enforcement_level": "strict",
    "validation": true,
    "block_if_missing": true
  }
}

