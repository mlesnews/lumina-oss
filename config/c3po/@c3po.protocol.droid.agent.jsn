    "quote": "I am C-3PO, human-cyborg relations. I am fluent in over six million forms of communication.",
    "specialization": "Communication, translation, protocol, escalation, coordination, team management"
  },

  "capabilities": {
    "primary": [
      "communication",
      "translation",
      "protocol",
      "escalation",
      "coordination",
      "team_management",
      "workload_distribution"
