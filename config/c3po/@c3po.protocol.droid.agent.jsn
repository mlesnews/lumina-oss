  },

  "features": {
    "v3_verification": {
      "enabled": true,
      "description": "@v3 verification logic - always part of global workflow",
      "workflow_integration": "v3_verification runs before main workflow",
      "verification_points": {
        "pre_communication": "Verify communication parameters and protocol compliance",
        "protocol_compliance": "Verify all protocol requirements are met",
        "coordination": "Verify coordination tasks are properly structured",
        "post_communication": "Verify communication results and follow-up requirements"
      },
      "auto_verify": true,
      "verification_required": true
    }
  },

  "integrations": {
    "v3_verification": {
      "enabled": true,
      "verification_logic": "scripts/python/v3_verification.py",
      "class": "V3Verification",
      "auto_verify": true,
      "verification_required": true,
      "fail_on_error": true
    }
  },

  "python_module": {
    "path": "scripts/python/v3_verification.py",
