{
  "environment_policy_rules": {
    "version": "1.0.0",
    "last_updated": "2026-01-02",
    "description": "Environment-specific policy rules for DEV, STAGING, and PROD environments",
    "change_request_policy": {
      "enabled": true,
      "immediate_execution_threshold_seconds": 120,
      "description": "If a @cr (change request) to environment-specific policy rules takes less than 2 minutes, execute immediately. Otherwise, schedule with NAS cron scheduler.",
      "environments": {
        "DEV": {
          "immediate_threshold_seconds": 120,
          "require_approval": false,
          "auto_schedule": true
        },
        "STAGING": {
          "immediate_threshold_seconds": 120,
          "require_approval": true,
          "auto_schedule": true
        },
        "PROD": {
          "immediate_threshold_seconds": 120,
          "require_approval": true,
          "auto_schedule": true,
          "require_rollback_plan": true
        }
      },
      "nas_cron_scheduler": {
        "enabled": true,
        "multi_platform": true,
        "supported_platforms": [
          "windows",
          "linux",
          "macos",
          "synology_dsm",
          "qnap",
          "docker"
        ],
        "default_schedule": "next_available_slot",
        "priority_levels": {
          "high": "immediate_next_slot",
          "medium": "within_1_hour",
          "low": "within_24_hours"
        }
      }
    },
    "ai_exploration_policy": {
      "enabled": true,
      "idle_time_threshold_seconds": 300,
      "description": "Limit AI/JARVIS @SMART explorations to idle time of more than 5 minutes. Do not interrupt active workflows or take over @op @input @manus @controls.",
      "restrictions": {
        "min_idle_time_seconds": 300,
        "check_workflow_activity": true,
        "check_user_input": true,
        "check_manus_controls": true,
        "check_operator_controls": true,
        "interrupt_threshold": "never",
        "background_only": true
      },
      "activity_checks": {
        "workflow_activity": {
          "enabled": true,
          "check_interval_seconds": 10,
          "activity_timeout_seconds": 60
        },
        "user_input": {
          "enabled": true,
          "check_interval_seconds": 5,
          "input_timeout_seconds": 30
        },
        "manus_controls": {
          "enabled": true,
          "check_interval_seconds": 5,
          "control_timeout_seconds": 30
        },
        "operator_controls": {
          "enabled": true,
          "check_interval_seconds": 5,
          "control_timeout_seconds": 30
        }
      },
      "allowed_during_idle": [
        "background_analysis",
        "pattern_discovery",
        "codebase_exploration",
        "optimization_suggestions",
        "documentation_generation"
      ],
      "forbidden_during_active": [
        "workflow_interruption",
        "control_takeover",
        "input_override",
        "manus_control_override",
        "operator_control_override"
      ]
    }
  }
}