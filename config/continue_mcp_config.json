{
  "version": "2.0",
  "name": "Continue MCP Configuration",
  "description": "Continue coding assistant configuration - Aligned with Docker MCP config for all IDEs",
  "last_updated": "2024-12-19",

  "continue": {
    "type": "coding_assistant",
    "name": "Continue",
    "extension_id": "continue.continue",
    "priority": "high",
    "status": "active",
    "config_file": "config/multi_ide_optimal_settings.json",
    "endpoint": "http://localhost:8080/assistants/continue",

    "capabilities": [
      "tab_autocomplete",
      "inline_completion",
      "local_llm_support",
      "multi_model_support"
    ],

    "integrations": [
      "ollama",
      "claude",
      "local_llm"
    ],

    "models": {
      "primary": "llama3.2:11b",
      "fallback": "codellama:13b"
    },

    "mcp": {
      "enabled": true,
      "hub_endpoint": "http://localhost:8080",
      "hub_health_check": "http://localhost:8080/health",
      "assistant_endpoint": "http://localhost:8080/assistants/continue",
      "unified_management": true
    },

    "ide_support": {
      "cursor": {
        "enabled": true,
        "priority": 2,
        "adapter_port": 8083
      },
      "vscode": {
        "enabled": true,
        "priority": 2,
        "adapter_port": 8082
      },
      "abacus": {
        "enabled": true,
        "priority": 2,
        "adapter_port": 8084
      }
    },

    "llama3.2:3b": {
      "primary_endpoint": "http://localhost:11434",
      "load_balancer": "http://localhost:11437",
      "enabled": true
    }
  }
}

