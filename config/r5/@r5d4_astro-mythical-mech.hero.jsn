        "production_validation": true
      },
      "n8n_workflow_automation": {
        "enabled": true,
        "webhook_url": "http://10.17.17.32:5678/webhook/r5"
      },
      "jupyter_notebook_analysis": {
        "enabled": true,
        "notebook_path": "data/jupyter"
      },
      "api_server": {
        "enabled": true,
