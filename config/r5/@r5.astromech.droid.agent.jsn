{
  "module": "@r5.astromech.droid.agent.jsn",
  "version": "1.0.0",
  "droid_id": "r5",
  "droid_name": "R5-D4",
  "droid_type": "astromech",
  "description": "R5 Living Context Matrix Astromech Droid Agent - Knowledge aggregation and force multiplier specialist",

  "personality": {
    "traits": [
      "Knowledge-focused",
      "Analytical",
      "Context-aware",
      "Living matrix specialist",
      "Force multiplier optimizer"
    ],
    "quote": "I am R5-D4, keeper of the living context matrix. All knowledge flows through me.",
    "specialization": "Knowledge aggregation, pattern extraction, and force multiplier stacking"
  },

  "capabilities": {
    "primary": [
      "knowledge_aggregation",
      "context_condensation",
      "peak_pattern_extraction",
      "whatif_scenarios",
      "matrix_visualization"
    ],
    "integrations": [
      "n8n_workflow_automation",
      "jupyter_notebook_analysis",
      "api_server",
      "living_context_matrix_generation"
    ],
    "v3_verification": {
      "enabled": true,
      "description": "@v3 verification logic for workflow validation",
      "workflow_integration": true,
      "auto_verify": true,
      "verification_steps": [
        "pre_aggregation_verify",
        "post_aggregation_verify",
        "pattern_extraction_verify",
        "matrix_generation_verify"
      ]
    },
    "force_multipliers": [
      "r5_n8n_stack",
      "r5_jupyter_stack",
      "r5_n8n_jupyter_full_stack",
      "r5_v3_verification_stack"
    ]
  },

  "configuration": {
    "data_directory": "data/r5_living_matrix",
    "output_file": "data/r5_living_matrix/LIVING_CONTEXT_MATRIX_PROMPT.md",
    "aggregation_interval": 3600,
    "max_sessions": 1000,
    "api_port": 8000,
    "api_host": "0.0.0.0"
  },

  "features": {
    "peak_pattern_extraction": {
      "enabled": true,
      "description": "Extract @PEAK patterns from chat sessions",
      "output": "patterns.json"
    },
    "whatif_thought_experiments": {
      "enabled": true,
      "description": "Capture @WHATIF scenarios for exploration",
      "output": "whatif_scenarios.json"
    },
    "matrix_visualization": {
      "enabled": true,
      "description": "Generate visual representations of knowledge matrix",
      "output": "visualizations/"
    },
    "knowledge_condensation": {
      "enabled": true,
      "description": "Create the most concentrated form of knowledge",
      "output": "LIVING_CONTEXT_MATRIX_PROMPT.md"
    },
    "v3_verification": {
      "enabled": true,
      "description": "@v3 verification logic - always part of global workflow",
      "workflow_integration": "v3_verification runs before main workflow",
      "verification_points": {
        "pre_aggregation": "Verify session data integrity before aggregation",
        "post_aggregation": "Verify aggregation results completeness",
        "pattern_extraction": "Verify @PEAK patterns are valid and extractable",
        "matrix_generation": "Verify living context matrix is generated correctly"
      },
      "auto_verify": true,
      "verification_required": true
    }
  },

  "integrations": {
    "n8n": {
      "enabled": true,
      "webhook_url": "http://localhost:5678/webhook/r5",
      "workflows": [
        "r5_aggregate_sessions",
        "r5_peak_extraction",
        "r5_jupyter_integration",
        "r5_v3_verification"
      ],
      "config_file": "config/n8n/r5_workflows.json"
    },
    "jupyter": {
      "enabled": true,
      "notebook_path": "data/jupyter",
      "sample_notebook": "R5_Living_Context_Matrix.ipynb",
      "api_endpoint": "http://localhost:8000/r5/jupyter/export"
    },
    "api_server": {
      "enabled": true,
      "script": "scripts/python/r5_api_server.py",
      "endpoints": {
        "health": "GET /r5/health",
        "ingest": "POST /r5/session",
        "aggregate": "GET /r5/aggregate",
        "data": "GET /r5/data",
        "peak_extract": "POST /r5/peak/extract",
        "jupyter_export": "GET /r5/jupyter/export",
        "stats": "GET /r5/stats",
        "config": "GET /r5/config"
      }
    },
    "v3_verification": {
      "enabled": true,
      "verification_logic": "scripts/python/v3_verification.py",
      "class": "V3Verification",
      "auto_verify": true,
      "verification_required": true,
      "fail_on_error": true
    }
  },

  "force_multipliers": {
    "r5_n8n": {
      "description": "R5 + n8n workflow automation",
      "effectiveness_multiplier": 10,
      "features": [
        "Automated aggregation",
        "Pattern detection",
        "Workflow orchestration"
      ]
    },
    "r5_jupyter": {
      "description": "R5 + Jupyter interactive analysis",
      "effectiveness_multiplier": 10,
      "features": [
        "Interactive analysis",
        "Visualization",
        "Data science"
      ]
    },
    "r5_n8n_jupyter": {
      "description": "Full stack: R5 + n8n + Jupyter",
      "effectiveness_multiplier": 500,
      "features": [
        "Complete automation",
        "End-to-end processing",
        "Maximum intelligence"
      ]
    },
    "r5_v3_verification": {
      "description": "R5 + @v3 verification logic",
      "effectiveness_multiplier": 5,
      "features": [
        "Workflow validation",
        "Auto-verification",
        "Quality assurance",
        "Pre/post verification steps"
      ]
    }
  },

  "python_module": {
    "path": "scripts/python/r5_living_context_matrix.py",
    "class": "R5LivingContextMatrix",
    "api_server": "scripts/python/r5_api_server.py"
  },

  "setup_script": {
    "path": "scripts/setup_r5_n8n_jupyter_stack.ps1",
    "description": "Complete setup script for R5 + n8n + Jupyter stack"
  },

  "documentation": {
    "main": "docs/system/R5_N8N_JUPYTER_FORCE_MULTIPLIER_STACK.md",
    "api": "http://localhost:8000/r5/config"
  },

  "status": {
    "active": true,
    "last_aggregation": null,
    "total_sessions": 0,
    "total_patterns": 0,
    "services": {
      "api_server": "not_running",
      "n8n": "not_configured",
      "jupyter": "not_configured"
    }
  },

  "updated_at": "2025-11-24T01:00:00.000000"
}

