{
  "default_manager": "idm",
  "managers": {
    "idm": {
      "enabled": true,
      "priority": 1,
      "path": "auto-detect",
      "cli_available": true,
      "com_api_available": true,
      "resume_support": true,
      "queue_support": true
    },
    "nas_dsm": {
      "enabled": true,
      "priority": 2,
      "host": "<NAS_PRIMARY_IP>",
      "port": 5000,
      "username": "mlesn",
      "api_endpoint": "/webapi/DownloadStation/task.cgi",
      "resume_support": true,
      "queue_support": true,
      "notes": "Synology Download Station - use for large files or when IDM unavailable"
    },
    "powershell": {
      "enabled": false,
      "priority": 3,
      "fallback_only": true,
      "resume_support": false
    }
  },
  "preferences": {
    "large_file_threshold_gb": 1.0,
    "use_nas_for_large_files": true,
    "auto_resume": true,
    "default_save_path": "M:\\models",
    "iron_legion_path": "D:\\Ollama\\models",
    "docker_volume_path": "/var/lib/docker/volumes/iron-legion-llamacpp_iron-legion-models/_data"
  },
  "iron_legion": {
    "use_idm": true,
    "prefer_nas_for_models": false,
    "fallback_to_powershell": false
  }
}
