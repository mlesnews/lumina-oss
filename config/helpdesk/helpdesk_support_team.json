  "workflow": {
    "ticket_received": {
      "step_1": "Helpdesk Analyst receives and triages ticket",
      "step_2": "Framework/Cloud specialist assigned based on ticket type",
      "step_3": "Technical Lead provides technical oversight",
      "step_4": "Team Manager coordinates and validates protocol",
      "step_5": "Ticket resolved and closed"
    },
    "framework_request": {
      "step_1": "Framework Specialist receives framework-specific request",
      "step_2": "Specialist coordinates with Docker if containerization needed",
      "step_3": "Technical Lead validates technical approach",
      "step_4": "Implementation and testing",
      "step_5": "Team Manager validates protocol compliance"
    },
    "cloud_platform_request": {
      "step_1": "Cloud Specialist receives cloud platform request",
      "step_2": "Specialist coordinates with framework specialists as needed",
      "step_3": "Technical Lead validates architecture",
      "step_4": "Implementation with security validation",
      "step_5": "Team Manager validates compliance"
    }
  },
  "framework_integrations": {
    "MANUS": {
      "enabled": true,
      "description": "Workstation control and automation framework",
      "integration_points": [
        "cursor_control",
        "ui_automation",
        "keyboard_control",
        "mouse_control",
        "screen_automation"
      ],
      "docker_container": "manus-mcp-server",
      "mcp_config": ".cursor/mcp_config.json",
      "specialist": "framework_specialist_manus"
    },
    "ELEVENLABS": {
      "enabled": true,
      "description": "Voice synthesis and audio processing framework",
      "integration_points": [
        "voice_synthesis",
        "text_to_speech",
        "audio_processing",
        "voice_cloning",
        "audio_workflows"
      ],
      "docker_container": "elevenlabs-mcp-server",
      "mcp_config": ".cursor/mcp_config.json",
      "specialist": "framework_specialist_elevenlabs"
    },
    "DOCKER": {
      "enabled": true,
      "description": "Container management and orchestration framework",
      "integration_points": [
        "container_management",
        "mcp_server_management",
        "container_orchestration",
        "container_deployment",
        "docker_networking"
      ],
      "docker_compose": "docker-compose.yml",
      "specialist": "framework_specialist_docker"
    },
    "n8n": {
      "enabled": true,
      "description": "Workflow automation and integration platform",
      "integration_points": [
        "workflow_automation",
        "email_hub_management",
        "webhook_management",
        "api_integration",
        "workflow_design"
      ],
      "config_location": "config/n8n/",
      "specialist": "workflow_specialist_n8n"
    }
  },
  "cloud_platform_integrations": {
    "Azure": {
      "enabled": true,
      "description": "Microsoft Azure cloud platform integration",
      "services": [
        "Azure Key Vault",
        "Azure OpenAI",
        "Azure Storage",
        "Azure Functions",
        "Azure Logic Apps"
      ],
      "config_location": "config/azure_openai_config.json",
      "key_vault": {
        "vault_name": "jarvis-lumina",
        "vault_url": "https://jarvis-lumina.vault.azure.net/",
        "secret_management": true
      },
      "specialist": "cloud_specialist_azure"
    },
    "AWS": {
      "enabled": true,
      "description": "Amazon Web Services cloud platform integration",
      "services": [
        "AWS Bedrock",
        "AWS S3",
        "AWS Lambda",
        "AWS Secrets Manager",
        "AWS CloudWatch"
      ],
      "config_location": "config/aws_bedrock_config.json",
      "credentials_storage": "Azure Key Vault",
      "specialist": "cloud_specialist_aws"
    }
  },
  "engagement_protocols": {
    "standard_workflow": [
      "1. Helpdesk Analyst receives and triages ticket",
      "2. Assign to appropriate framework/cloud specialist",
      "3. Technical Lead provides technical oversight",
      "4. Team Manager validates protocol compliance",
      "5. Ticket resolved and closed"
    ],
    "framework_workflow": [
      "1. Framework Specialist receives request",
      "2. Coordinate with Docker specialist if containerization needed",
      "3. Technical Lead validates approach",
      "4. Implementation and testing",
      "5. Team Manager validates compliance"
    ],
    "cloud_platform_workflow": [
      "1. Cloud Specialist receives request",
      "2. Coordinate with framework specialists as needed",
      "3. Technical Lead validates architecture",
      "4. Implementation with security validation",
      "5. Team Manager validates compliance"
    ]
  },
