  "team_metadata": {
    "team_id": "eco_backup_team",
    "team_name": "ECO Backup Team",
    "description": "Fully robust and comprehensive ecosystem backup team. Handles all backup operations across the entire company ecosystem - NAS backups, local enterprise backups, cloud backups, disaster recovery, bare-metal recovery, and complete infrastructure protection. Ensures zero data loss and complete business continuity.",
