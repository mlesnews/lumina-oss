    "goldilocks_zone": {
      "description": "The optimal operating range - not too resource-heavy (hot), not too idle (cold)",
      "zones": {
        "TOO_COLD": {
          "description": "System underutilized - wasting capacity",
          "indicators": {
            "cpu_utilization_below": 20,
            "memory_utilization_below": 30,
            "concurrent_agents_below": 1
          },
          "action": "Consider enabling more services or DYNO mode"
        },
        "GOLDILOCKS": {
          "description": "Just right - optimal performance",
          "indicators": {
            "cpu_utilization_range": [40, 70],
            "memory_utilization_range": [40, 60],
            "cursor_memory_range_mb": [2000, 4000],
            "concurrent_agents_range": [1, 3],
            "response_time_ms_below": 500,
            "econnreset_errors_per_hour": 0
          },
          "action": "Maintain current state - OPTIMAL"
        },
        "TOO_HOT": {
          "description": "System overloaded - risk of failures",
          "indicators": {
            "cpu_utilization_above": 85,
            "memory_utilization_above": 80,
            "cursor_memory_above_mb": 6000,
            "concurrent_agents_above": 4,
            "econnreset_errors_per_hour_above": 1
          },
          "action": "IMMEDIATE: Reduce load, run cursor_health_recovery.ps1"
        }
      }
    },

    "dyno_testing_framework": {
      "description": "Systematic approach to finding min/max bounds",
      "phases": [
        {
          "phase": 1,
          "name": "BASELINE",
          "description": "Establish current performance baseline at 50% capacity",
          "duration_hours": 24,
          "metrics_collected": [
            "memory_usage_avg",
            "cpu_usage_avg",
            "response_times_p50_p95_p99",
            "error_rates",
            "throughput"
          ],
          "success_criteria": "Zero ECONNRESET errors for 24 hours"
        },
        {
          "phase": 2,
          "name": "RAMP_UP",
          "description": "Gradually increase load to find upper bounds",
          "increments": [60, 70, 80, 90, 100],
          "hold_duration_minutes": 30,
          "metrics_collected": [
            "breaking_point_capacity_percent",
            "first_error_threshold",
            "performance_degradation_curve"
          ],
          "success_criteria": "Identify MAX capacity without errors"
        },
        {
          "phase": 3,
          "name": "RAMP_DOWN",
          "description": "Find minimum viable capacity",
          "decrements": [50, 40, 30, 25, 20],
          "hold_duration_minutes": 15,
          "metrics_collected": [
            "minimum_functional_capacity",
            "idle_resource_baseline"
          ],
          "success_criteria": "Identify MIN capacity for operations"
        },
        {
          "phase": 4,
          "name": "GOLDILOCKS_CALIBRATION",
          "description": "Fine-tune to optimal zone",
          "target": "Center of safe operating range",
          "method": "Binary search between MIN and MAX",
          "success_criteria": "Stable operation with 20% headroom"
        },
        {
          "phase": 5,
          "name": "BURN_IN",
          "description": "Extended testing at Goldilocks capacity",
          "duration_hours": 48,
          "load_type": "Production-like workload",
          "success_criteria": "Zero errors, stable metrics for 48 hours"
        }
      ],

      "dyno_commands": {
        "start_dyno": "python scripts/python/dyno_performance_test.py --mode ramp_up",
        "check_status": "python scripts/python/dyno_performance_test.py --status",
        "emergency_stop": "python scripts/python/dyno_performance_test.py --abort",
        "get_report": "python scripts/python/dyno_performance_test.py --report"
      }
    },

    "metrics_collection": {
      "real_time_gauges": [
        {
          "metric": "cursor_memory_total_mb",
          "source": "cursor_health_recovery.ps1 -Analyze",
          "threshold_warning": 4000,
          "threshold_critical": 6000
        },
        {
          "metric": "cursor_process_count",
          "source": "Get-Process Cursor | Measure-Object",
          "threshold_warning": 20,
          "threshold_critical": 30
        },
        {
          "metric": "econnreset_count_hourly",
          "source": "cursor_error_handling logs",
          "threshold_warning": 1,
          "threshold_critical": 3
        },
        {
          "metric": "ai_tokens_per_second",
          "source": "ultron_cluster_burnin_test.py",
          "threshold_warning": 10,
          "threshold_optimal": 50
        }
      ],

      "historical_metrics": {
        "storage_path": "data/performance_metrics/",
        "retention_days": 90,
        "aggregation_intervals": ["1min", "5min", "1hour", "1day"]
      }
    },

