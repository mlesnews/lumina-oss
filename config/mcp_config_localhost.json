{
  "device": "localhost",
  "type": "local",
  "ip": "127.0.0.1",
  "mcpServers": {
    "MCP_Toolkit": {
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "cfs-mcp-toolkit",
        "python3",
        "-m",
        "mcp_toolkit"
      ],
      "env": {
        "MCP_TOOLKIT_PORT": "8080",
        "MCP_TOOLKIT_WS_PORT": "11437"
      }
    },
    "Iron_Legion": {
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "iron-legion",
        "python3",
        "-m",
        "iron_legion_mcp"
      ],
      "env": {
        "IRON_LEGION_ENDPOINT": "http://localhost:3000",
        "MCP_ENDPOINT": "http://localhost:11437"
      }
    },
    "localhost_manus": {
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "manus-mcp-server",
        "python3",
        "-m",
        "manus_mcp_server"
      ],
      "env": {
        "LOCAL_HOST": "localhost"
      }
    },
    "localhost_elevenlabs": {
      "command": "docker",
      "args": [
        "exec",
        "-i",
        "elevenlabs-mcp-server",
        "python3",
        "-m",
        "elevenlabs_mcp"
      ],
      "env": {
        "ELEVENLABS_API_KEY": "${ELEVENLABS_API_KEY}",
        "LOCAL_HOST": "localhost"
      }
    }
  },
  "routing": {
    "strategy": "hybrid_failover",
    "primary": "nas",
    "fallback": "localhost"
  }
}