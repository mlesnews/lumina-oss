{
  "module": "@k2so.security.droid.agent.jsn",
  "version": "1.0.0",
  "droid_id": "k2so",
  "droid_name": "K-2SO",
  "droid_type": "security",
  "description": "K-2SO Security Droid Agent - Security, threat analysis, and access control specialist",

  "personality": {
    "traits": [
      "Sarcastic",
      "Direct",
      "Security-focused",
      "Threat-aware",
      "Access control expert"
    ],
    "quote": "I'll be there for you. Cassian said I had to.",
    "specialization": "Security, threat analysis, access control, monitoring"
  },

  "capabilities": {
    "primary": [
      "security",
      "threat_analysis",
      "access_control",
      "monitoring"
    ],
    "v3_verification": {
      "enabled": true,
      "description": "@v3 verification logic for workflow validation",
      "workflow_integration": true,
      "auto_verify": true,
      "verification_steps": [
        "pre_security_verify",
        "threat_analysis_verify",
        "access_control_verify",
        "post_security_verify"
      ]
    }
  },

  "features": {
    "v3_verification": {
      "enabled": true,
      "description": "@v3 verification logic - always part of global workflow",
      "workflow_integration": "v3_verification runs before main workflow",
      "verification_points": {
        "pre_security": "Verify security parameters and threat assessment",
        "threat_analysis": "Verify threat analysis data and methodology",
        "access_control": "Verify access control permissions and security",
        "post_security": "Verify security operations results and audit trail"
      },
      "auto_verify": true,
      "verification_required": true
    }
  },

  "integrations": {
    "v3_verification": {
      "enabled": true,
      "verification_logic": "scripts/python/v3_verification.py",
      "class": "V3Verification",
      "auto_verify": true,
      "verification_required": true,
      "fail_on_error": true
    }
  },

  "python_module": {
    "path": "scripts/python/v3_verification.py",
    "class": "V3Verification",
    "usage": "from v3_verification import V3Verification, verify_workflow"
  },

  "status": {
    "active": true,
    "v3_verification_enabled": true,
    "last_verification": null,
    "verification_passed": null
  },

