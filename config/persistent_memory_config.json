{
  "persistent_memory": {
    "enabled": true,
    "auto_digest": true,
    "explanation_threshold": 0,
    "workflow_auto_process": true
  },
  "holocrons": {
    "enabled": true,
    "storage_path": "data/holocrons",
    "auto_store": true,
    "importance_threshold": 3
  },
  "database": {
    "enabled": true,
    "auto_store": true,
    "workflow_history": true,
    "analytics_history": true
  },
  "youtube_content": {
    "enabled": true,
    "auto_generate": true,
    "importance_threshold": 4
  },
  "importance_scoring": {
    "system": "5_plus_star",
    "levels": {
      "1": {"min": 0, "max": 20, "symbol": "+"},
      "2": {"min": 21, "max": 40, "symbol": "++"},
      "3": {"min": 41, "max": 60, "symbol": "+++"},
      "4": {"min": 61, "max": 80, "symbol": "++++"},
      "5": {"min": 81, "max": 100, "symbol": "+++++"}
    },
    "auto_score": true
  },
  "workflow_processing": {
    "auto_execute": true,
    "minimal_explanation": true,
    "store_to_holocron": true,
    "store_to_db": true,
    "generate_content": true
  }
}
