        "validation": false,
        "use_cases": [
          "General problem-solving",
          "Code review",
          "System maintenance"
        ]
      },
      {
        "id": "rule_002",
        "name": "@RR + Security Context",
        "tags": ["@RR", "@COMPUSEC"],
        "rr_definition": "secondary",
        "behavior": "Rapid Response",
        "speed": "fast",
        "validation": true,
        "use_cases": [
          "Security threats",
          "Urgent security operations"
        ]
      },
      {
        "id": "rule_003",
        "name": "@RR + Execution Context",
        "tags": ["@RR", "@DOIT"],
        "rr_definition": "secondary",
        "behavior": "Rapid Response",
        "speed": "fastest",
        "validation": false,
        "use_cases": [
          "Autonomous execution",
          "Urgent deployments"
        ]
      },
      {
        "id": "rule_004",
        "name": "@RR + Threat Response",
        "tags": ["@RR", "@F4"],
