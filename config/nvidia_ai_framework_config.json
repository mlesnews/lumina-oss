{
  "version": "1.0.0",
  "name": "NVIDIA AI Framework Integration",
  "description": "Integration with NVIDIA AI Framework (NIMs, NGC) for GPU-optimized AI models",
  "last_updated": "2025-01-24",
  "status": "planning",
  
  "api": {
    "platform": "NVIDIA AI Framework",
    "nim_api": "https://build.nvidia.com",
    "ngc_catalog": "https://catalog.ngc.nvidia.com",
    "api_documentation": "https://docs.nvidia.com/nim/",
    "catalog_url": "https://build.nvidia.com/models"
  },
  
  "authentication": {
    "method": "api_key",
    "api_key_source": "azure_key_vault",
    "key_vault": {
      "vault_name": "jarvis-lumina",
      "vault_url": "https://jarvis-lumina.vault.azure.net/",
      "secret_name": "nvidia-api-key"
    },
    "alternatives": ["ngc_api_key", "environment_variable"]
  },
  
  "model_catalog": {
    "nim_models": {
      "enabled": true,
      "description": "NVIDIA Inference Microservices - Production-ready containers",
      "categories": [
        "llm",
        "vision",
        "speech",
        "code",
        "multimodal",
        "embeddings"
      ]
    },
    "ngc_models": {
      "enabled": true,
      "description": "NVIDIA GPU Cloud - Optimized containers and models",
      "categories": [
        "llm",
        "computer_vision",
        "speech_ai",
        "recommender_systems",
        "robotics"
      ]
    }
  },
  
  "download": {
    "default_location": "nas",
    "selective_download": true,
    "download_only_what_we_use": true,
    "concurrent_downloads": 2,
    "retry_attempts": 3,
    "resume_support": true,
    "verify_downloads": true,
    "progress_tracking": true
  },
  
  "storage": {
    "nas": {
      "enabled": true,
      "hostname": "kaiju_no_8",
      "ip": "<NAS_PRIMARY_IP>",
      "protocol": "smb",
      "mount_point_windows": "\\\\<NAS_PRIMARY_IP>\\models",
      "base_path": "/volume1/models/nvidia",
      "alternatives": ["nfs", "ssh"]
    },
    "local_cache": {
      "enabled": true,
      "path": "data/models/cache/nvidia",
      "max_size_gb": 50
    }
  },
  
  "hardware": {
    "gpu_required": true,
    "cuda_required": true,
    "recommended_gpus": [
      "RTX 3090",
      "RTX 4090",
      "RTX 5090",
      "A100",
      "H100"
    ],
    "kaiju_gpu": {
      "model": "RTX 3090",
      "vram_gb": 24,
      "cuda_cores": 10496,
      "status": "available"
    }
  },
  
  "deployment": {
    "targets": {
      "docker": {
        "enabled": true,
        "format": "container",
        "runtime": "docker",
        "nvidia_runtime": "nvidia-container-runtime",
        "types": ["nim", "ngc"]
      },
      "triton_inference": {
        "enabled": true,
        "format": "triton",
        "types": ["optimized_models"]
      },
      "onnx_runtime": {
        "enabled": true,
        "format": "onnx",
        "cuda_provider": true
      }
    }
  },
  
  "integration": {
    "ultron": {
      "enabled": false,
      "note": "NVIDIA models typically require containers, not Ollama"
    },
    "iron_legion": {
      "enabled": false,
      "note": "NVIDIA models typically require containers, not Ollama"
    },
    "docker": {
      "enabled": true,
      "primary_deployment": true
    }
  },
  
  "documentation": {
    "integration_guide": "docs/system/NVIDIA_AI_FRAMEWORK_INTEGRATION.md",
    "api_docs": "https://docs.nvidia.com/nim/",
    "ngc_catalog": "https://catalog.ngc.nvidia.com",
    "setup_guide": "docs/system/NVIDIA_SETUP_GUIDE.md"
  }
}
