  "messengers": {
    "telegram": {
      "status": "pending_setup",
      "n8n_node": "Telegram",
      "n8n_trigger": "Telegram Trigger",
      "setup_steps": [
        "1. Message @BotFather on Telegram",
        "2. Create new bot with /newbot",
        "3. Copy the bot token",
        "4. Store token in n8n credentials",
        "5. Create workflow with Telegram Trigger node"
      ],
      "n8n_workflow": "messenger_telegram",
      "enabled": false,
      "notes": "Free, no phone verification needed for bot"
    },
    "discord": {
      "status": "pending_setup",
      "n8n_node": "Discord",
      "n8n_trigger": "Discord Trigger",
      "setup_steps": [
        "1. Go to https://discord.com/developers/applications",
        "2. Create new application",
        "3. Create Bot in application settings",
        "4. Copy bot token",
        "5. Enable Privileged Gateway Intents",
        "6. Invite bot to server with OAuth2 URL Generator",
        "7. Store token in n8n credentials",
        "8. Create workflow with Discord node"
      ],
      "n8n_workflow": "messenger_discord",
      "enabled": false,
      "notes": "Requires server admin to invite bot"
    },
    "whatsapp": {
      "status": "pending_setup",
      "n8n_node": "WhatsApp Business Cloud",
      "n8n_trigger": "WhatsApp Trigger",
      "setup_steps": [
        "1. Create Meta Business account",
        "2. Go to https://developers.facebook.com",
        "3. Create new app (Business type)",
        "4. Add WhatsApp product to app",
        "5. Get phone number ID and access token",
        "6. Configure webhook for incoming messages",
        "7. Store credentials in n8n",
        "8. Create workflow with WhatsApp nodes"
      ],
      "n8n_workflow": "messenger_whatsapp",
      "enabled": false,
      "notes": "Business API - free tier available for testing"
    },
    "slack": {
      "status": "pending_setup",
      "n8n_node": "Slack",
      "n8n_trigger": "Slack Trigger",
      "setup_steps": [
        "1. Go to https://api.slack.com/apps",
        "2. Create new app 'From scratch'",
        "3. Add OAuth scopes (chat:write, channels:read, etc.)",
        "4. Install app to workspace",
        "5. Copy Bot User OAuth Token",
        "6. Enable Event Subscriptions for triggers",
        "7. Store token in n8n credentials"
      ],
      "n8n_workflow": "messenger_slack",
      "enabled": false,
      "notes": "For company/team communication"
    },
    "signal": {
      "status": "pending_setup",
      "n8n_node": "HTTP Request",
      "n8n_trigger": "Webhook",
      "setup_steps": [
        "1. Set up signal-cli or signal-cli-rest-api Docker container",
        "2. Register/link phone number",
        "3. Configure REST API endpoint",
        "4. Create n8n workflow with HTTP Request to Signal API"
      ],
      "n8n_workflow": "messenger_signal",
      "enabled": false,
      "notes": "Requires signal-cli-rest-api container - most secure"
    }
  },

  "n8n_master_workflows": {
    "unified_inbox": {
      "description": "Aggregates all 9 email endpoints into single stream",
      "status": "pending",
      "triggers": ["IMAP Email", "Gmail API", "Webhook"],
      "outputs": ["Holocron", "SYPHON", "Notification"],
      "transport": "@NDM"
    },
    "message_router": {
      "description": "Routes incoming messages to appropriate handlers",
      "status": "pending",
      "triggers": ["Telegram Trigger", "Discord Trigger", "WhatsApp Trigger", "Webhook"],
      "outputs": ["@JARVIS", "@TRIAGE", "@ASK"],
      "transport": "@NDM"
    },
    "notification_hub": {
      "description": "Sends notifications to multiple channels",
      "status": "pending",
      "triggers": ["Webhook from LUMINA"],
      "outputs": ["Email", "SMS", "Telegram", "Discord"]
    },
    "ndm_secure_transport": {
      "description": "@NDM - Secure data transport without tickets",
      "status": "pending",
      "philosophy": "Tickets are for humans. NDMs are for machines.",
      "triggers": ["Webhook from UHURA/C3PO pipelines"],
      "outputs": ["@SYPHON", "@HOLOCRON"],
      "security": {
        "encryption": "TLS 1.3",
        "audit_log": "data/ndm_logs/",
        "no_pii_in_logs": true
      },
      "ticket_policy": "NO TICKETS - silent operation by design"
    }
  },

  "todolist_requirements": {
    "description": "User requirement for dual todolist display in AI chat sessions",
    "master_todolist": {
      "description": "Persistent todolist across sessions",
