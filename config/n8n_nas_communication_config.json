    "session_todolist": {
      "description": "Current session todolist (existing Cursor chat behavior)",
      "features": ["auto_collapse", "auto_hide", "session_scoped"],
      "status": "active"
    },
    "display_requirement": "Both todolists visible in every AI chat session",
    "ui_behavior": "Identical to current Cursor chat todolist - auto collapse/hide"
  },

