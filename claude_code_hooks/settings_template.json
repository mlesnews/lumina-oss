{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "_comment": "Copy relevant sections into ~/.claude/settings.json",

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/compusec_guard.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/trace_track.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/cost_tracker.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash|Read|Grep|WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/secrets_redactor.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|Bash|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/wakatime_heartbeat.py",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/fast_mode_tracker.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/precompact_snapshot.py",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/api_watchdog.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/session_compiler.py",
            "timeout": 30
          }
        ]
      }
    ]
  },

  "statusLine": {
    "_comment": "Dynamic status bar — create your own with StatusLineBuilder",
    "type": "command",
    "command": "python3 ~/.claude/hooks/my_statusline.py",
    "padding": 3
  }
}
